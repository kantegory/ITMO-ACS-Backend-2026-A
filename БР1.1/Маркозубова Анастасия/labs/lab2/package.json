{
  "name": "lab2-job-board-microservices",
  "version": "1.0.0",
  "description": "A complex production-ready boilerplate based on express and typeorm",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:auth && npm run build:profile && npm run build:resume && npm run build:vacancy && npm run build:application && npm run build:reference",
    "build:auth": "npx tsc -p auth-service/tsconfig.json",
    "build:profile": "npx tsc -p profile-service/tsconfig.json",
    "build:resume": "npx tsc -p resume-service/tsconfig.json",
    "build:vacancy": "npx tsc -p vacancy-service/tsconfig.json",
    "build:application": "npx tsc -p application-service/tsconfig.json",
    "build:reference": "npx tsc -p reference-service/tsconfig.json",
    "db:create": "powershell -ExecutionPolicy Bypass -File scripts/create-databases.ps1",
    "seed:demo": "node scripts/seed-demo-data.js",
    "start:auth": "cd auth-service && npx tsx --env-file=.env dist/app.js",
    "start:profile": "cd profile-service && npx tsx --env-file=.env dist/app.js",
    "start:resume": "cd resume-service && npx tsx --env-file=.env dist/app.js",
    "start:vacancy": "cd vacancy-service && npx tsx --env-file=.env dist/app.js",
    "start:application": "cd application-service && npx tsx --env-file=.env dist/app.js",
    "start:reference": "cd reference-service && npx tsx --env-file=.env dist/app.js",
    "start:services": "powershell -ExecutionPolicy Bypass -File scripts/start-services.ps1",
    "start": "npm run start:services",
    "dev": "npm run start:services"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "class-validator-jsonschema": "^5.0.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.14.0",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "0.11.0",
    "routing-controllers-openapi": "git+https://github.com/kantegory/routing-controllers-openapi.git",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.21"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "@types/swagger-ui-express": "^4.1.8",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "private": true
}
