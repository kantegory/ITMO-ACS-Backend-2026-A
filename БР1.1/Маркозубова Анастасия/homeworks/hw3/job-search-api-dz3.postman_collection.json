        {
          "name": "4. References - Get Specializations",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Список специализаций получен', function () {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "const items = pm.response.json();",
                  "pm.test('Справочник специализаций не пустой', function () {",
                  "    pm.expect(items).to.be.an('array').and.not.empty;",
                  "});",
                  "const backendSpec = items.find((item) => String(item.name || '').toLowerCase().includes('backend'));",
                  "const selected = backendSpec || items[0];",
                  "pm.collectionVariables.set('specializationId', String(selected.specialization_id));",
                  "pm.collectionVariables.set('specializationName', String(selected.name));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/specializations"
          }
        },
        {
          "name": "5. Company - Create Vacancy",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Вакансия создана', function () {",
