            "url": "{{baseUrl}}/companies"
          }
        },
        {
          "name": "5. Resumes - Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Несуществующее резюме возвращает 404', function () {",
                  "    pm.expect(pm.response.code).to.eql(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/resumes/999999999"
          }
        },
        {
          "name": "6. Applications - Duplicate Apply",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Повторный отклик даёт 409', function () {",
                  "    pm.expect(pm.response.code).to.eql(409);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{seekerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resume_id\": {{resumeId}},\n  \"cover_letter\": \"Повторный отклик для проверки 409\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/vacancies/{{selectedVacancyId}}/applications"
          }
        }
      ]
    }
  ]
}
