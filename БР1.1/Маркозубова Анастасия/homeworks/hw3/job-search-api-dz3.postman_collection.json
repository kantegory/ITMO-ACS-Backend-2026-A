    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8002/api"
    },
    {
      "key": "companyPassword",
      "value": "qwerty123"
    },
    {
      "key": "seekerPassword",
      "value": "qwerty123"
    }
  ],
  "item": [
    {
      "name": "Сквозной сценарий",
      "item": [
        {
          "name": "1. Company - Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = String(Date.now());",
                  "pm.collectionVariables.set('uniqueSuffix', suffix);",
                  "pm.collectionVariables.set('companyEmail', `hw3.company.${suffix}@example.com`);",
                  "pm.collectionVariables.set('seekerEmail', `hw3.seeker.${suffix}@example.com`);",
                  "pm.collectionVariables.set('companyName', `HW3 Company ${suffix}`);",
                  "pm.collectionVariables.set('vacancyTitle', `Backend Node.js ${suffix}`);",
                  "pm.collectionVariables.set('vacancyLocation', `Москва HW3 ${suffix}`);",
                  "pm.collectionVariables.set('resumeTitle', `Backend Developer ${suffix}`);",
                  "pm.collectionVariables.unset('companyToken');",
                  "pm.collectionVariables.unset('seekerToken');",
                  "pm.collectionVariables.unset('specializationId');",
                  "pm.collectionVariables.unset('companyId');",
                  "pm.collectionVariables.unset('seekerId');",
                  "pm.collectionVariables.unset('resumeId');",
                  "pm.collectionVariables.unset('createdVacancyId');",
                  "pm.collectionVariables.unset('selectedVacancyId');",
                  "pm.collectionVariables.unset('applicationId');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Компания зарегистрирована', function () {",
                  "    pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Роль компании корректна', function () {",
                  "    pm.expect(json.user.role).to.eql('company');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{companyEmail}}\",\n  \"password\": \"{{companyPassword}}\",\n  \"role\": \"company\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "2. Company - Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Компания вошла в систему', function () {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "const json = pm.response.json();",
                  "const token = json.accessToken || json.access_token;",
                  "pm.collectionVariables.set('companyToken', token);",
                  "pm.collectionVariables.set('companyUserId', String(json.user.user_id));",
                  "pm.test('Токен компании сохранён', function () {",
                  "    pm.expect(token).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{companyEmail}}\",\n  \"password\": \"{{companyPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "3. Company - Create Profile",
