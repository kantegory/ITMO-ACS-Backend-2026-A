            "body": {
              "mode": "raw",
              "raw": "{\n  \"specialization_id\": {{specializationId}},\n  \"title\": \"{{vacancyTitle}}\",\n  \"description\": \"Вакансия для проверки сценария в Postman\",\n  \"requirements\": \"Node.js, TypeScript, REST API\",\n  \"salary_min\": 150000,\n  \"salary_max\": 220000,\n  \"experience_required\": 2,\n  \"location\": \"{{vacancyLocation}}\",\n  \"work_format\": \"remote\",\n  \"employment_type\": \"full-time\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/vacancies"
          }
        },
        {
          "name": "6. Vacancies - Filter List",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Список вакансий по фильтру получен', function () {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "const items = pm.response.json();",
                  "pm.test('После фильтрации есть хотя бы одна вакансия', function () {",
                  "    pm.expect(items).to.be.an('array').and.not.empty;",
                  "});",
                  "const filtered = items.filter((item) => item.location === pm.collectionVariables.get('vacancyLocation'));",
                  "pm.test('Фильтр по уникальной локации сработал', function () {",
                  "    pm.expect(filtered.length).to.be.greaterThan(0);",
                  "});",
                  "const selected = filtered[Math.floor(Math.random() * filtered.length)];",
                  "pm.collectionVariables.set('selectedVacancyId', String(selected.vacancy_id));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vacancies?specialization_id={{specializationId}}&location={{vacancyLocation}}"
          }
        },
