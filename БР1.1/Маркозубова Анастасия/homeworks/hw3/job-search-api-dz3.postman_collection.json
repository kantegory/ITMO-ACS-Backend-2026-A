                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('createdVacancyId', String(json.vacancy_id));",
                  "pm.test('ID вакансии сохранён', function () {",
                  "    pm.expect(json.vacancy_id).to.exist;",
                  "});"
                ]
              }
            }
