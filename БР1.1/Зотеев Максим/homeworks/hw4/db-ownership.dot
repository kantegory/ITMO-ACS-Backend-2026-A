digraph DbOwnership {
  graph [
    rankdir=LR,
    splines=ortho,
    nodesep=0.5,
    ranksep=0.9,
    pad=0.2,
    bgcolor="white"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Arial",
    fontsize=12,
    color="#2b2d42",
    fillcolor="#edf2f4",
    margin="0.16,0.10"
  ];

  edge [
    color="#8d99ae",
    penwidth=1.2,
    arrowsize=0.8,
    fontname="Arial",
    fontsize=10
  ];

  gateway [label="API Gateway\n(no database)", fillcolor="#d9f0ff"];

  subgraph cluster_identity {
    label="Identity Service / Identity DB";
    color="#4c78a8";
    style="rounded";
    fontname="Arial Bold";
    users [label="users", fillcolor="#e8f1fb"];
  }

  subgraph cluster_property {
    label="Property Service / Property DB";
    color="#59a14f";
    style="rounded";
    fontname="Arial Bold";
    properties [label="properties", fillcolor="#edf8ea"];
    locations [label="locations", fillcolor="#edf8ea"];
    property_photos [label="property_photos", fillcolor="#edf8ea"];
    property_types [label="property_types", fillcolor="#edf8ea"];
    amenities [label="amenities", fillcolor="#edf8ea"];
    property_amenities [label="property_amenities", fillcolor="#edf8ea"];
  }

  subgraph cluster_rental {
    label="Rental Service / Rental DB";
    color="#f28e2b";
    style="rounded";
    fontname="Arial Bold";
    rentals [label="rentals\n+ property_title_snapshot\n+ property_city_snapshot\n+ price_per_month_snapshot", fillcolor="#fff0e1"];
  }

  subgraph cluster_message {
    label="Messaging Service / Messaging DB";
    color="#e15759";
    style="rounded";
    fontname="Arial Bold";
    messages [label="messages", fillcolor="#fdebec"];
  }

  gateway -> users [label="/auth, /users"];
  gateway -> properties [label="/properties"];
  gateway -> rentals [label="/rentals"];
  gateway -> messages [label="/messages"];

  rentals -> properties [label="property_id (service call)"];
  rentals -> users [label="tenant_id, owner_id (service call)"];
  messages -> rentals [label="rental_id (service call)"];

  properties -> locations [arrowhead=none, color="#59a14f"];
  properties -> property_photos [arrowhead=none, color="#59a14f"];
  properties -> property_types [arrowhead=none, color="#59a14f"];
  properties -> property_amenities [arrowhead=none, color="#59a14f"];
  property_amenities -> amenities [arrowhead=none, color="#59a14f"];
}
