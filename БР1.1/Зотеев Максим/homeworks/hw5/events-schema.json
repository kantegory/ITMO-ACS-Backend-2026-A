{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://itmo.example/rental/events.json",
  "title": "Rental Platform Async Events",
  "description": "Схемы JSON-сообщений, публикуемых в exchange rental.events (topic, durable).",
  "definitions": {
    "UserRegistered": {
      "type": "object",
      "description": "Опубликовано identity-service при успешной регистрации (routing key: user.registered).",
      "required": ["user_id", "email", "role", "occurred_at"],
      "additionalProperties": false,
      "properties": {
        "user_id": { "type": "string", "description": "ID пользователя" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["tenant", "landlord"] },
        "occurred_at": { "type": "string", "format": "date-time" }
      }
    },
    "RentalCreated": {
      "type": "object",
      "description": "Опубликовано rental-service после успешной фиксации сделки (routing key: rental.created).",
      "required": ["rental_id", "property_id", "tenant_id", "owner_id", "occurred_at"],
      "additionalProperties": false,
      "properties": {
        "rental_id": { "type": "string" },
        "property_id": { "type": "string" },
        "property_title": { "type": "string" },
        "tenant_id": { "type": "string" },
        "owner_id": { "type": "string" },
        "occurred_at": { "type": "string", "format": "date-time" }
      }
    },
    "RentalCompleted": {
      "type": "object",
      "description": "Опубликовано rental-service после успешного завершения сделки (routing key: rental.completed).",
      "required": ["rental_id", "property_id", "tenant_id", "owner_id", "occurred_at"],
      "additionalProperties": false,
      "properties": {
        "rental_id": { "type": "string" },
        "property_id": { "type": "string" },
        "tenant_id": { "type": "string" },
        "owner_id": { "type": "string" },
        "occurred_at": { "type": "string", "format": "date-time" }
      }
    },
    "RentalCancelled": {
      "type": "object",
      "description": "Опубликовано rental-service после отмены сделки (routing key: rental.cancelled).",
      "required": ["rental_id", "property_id", "tenant_id", "owner_id", "occurred_at"],
      "additionalProperties": false,
      "properties": {
        "rental_id": { "type": "string" },
        "property_id": { "type": "string" },
        "tenant_id": { "type": "string" },
        "owner_id": { "type": "string" },
        "occurred_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
