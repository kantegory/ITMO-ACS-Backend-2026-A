        "pm.test('видим завершённую', () => pm.expect(j.content.map(r => r.status)).to.include('completed'));"
      ]}}]
    },
    {
      "name": "58. Landlord A: /users/me/rentals?status=completed",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{landlord_token}}" }],
        "url": {
          "raw": "{{base_url}}/users/me/rentals?status=completed",
          "host": ["{{base_url}}"],
          "path": ["users","me","rentals"],
          "query": [{ "key": "status", "value": "completed" }]
        }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 200', () => pm.response.to.have.status(200));",
        "const j = pm.response.json();",
        "pm.test('все completed', () => j.content.forEach(r => pm.expect(r.status).to.eql('completed')));",
        "pm.test('>= 1', () => pm.expect(j.total_elements).to.be.at.least(1));"
      ]}}]
    },
    {
      "name": "59. Tenant 2 заново арендует освободившийся property #1",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{tenant_b_token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "{{base_url}}/properties/{{property_id}}/rentals", "host": ["{{base_url}}"], "path": ["properties","{{property_id}}","rentals"] },
        "body": { "mode": "raw", "raw": "{\n  \"start_date\": \"2027-01-01\"\n}" }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 201 (объект снова свободен)', () => pm.response.to.have.status(201));",
        "const j = pm.response.json();",
        "pm.test('snapshot title — НОВЫЙ', () => pm.expect(j.property_title_snapshot).to.eql('ИЗМЕНЁННЫЙ ЗАГОЛОВОК'));",
        "pm.test('snapshot price — НОВЫЙ (99999)', () => pm.expect(j.price_per_month_snapshot).to.eql(99999));"
      ]}}]
    },
    {
      "name": "60. Internal endpoint через gateway → 404 (скрыт)",
      "request": { "method": "GET", "url": { "raw": "{{base_url}}/internal/users/1", "host": ["{{base_url}}"], "path": ["internal","users","1"] } },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 404 (gateway не пробрасывает internal)', () => pm.response.to.have.status(404));"
      ]}}]
    },
    {
      "name": "61. DELETE property by other landlord → 403",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{landlord_b_token}}" }],
        "url": { "raw": "{{base_url}}/properties/{{property_b_id}}", "host": ["{{base_url}}"], "path": ["properties","{{property_b_id}}"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 403', () => pm.response.to.have.status(403));"
      ]}}]
    },
    {
      "name": "62. DELETE property by owner → 204",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{landlord_token}}" }],
        "url": { "raw": "{{base_url}}/properties/{{property_b_id}}", "host": ["{{base_url}}"], "path": ["properties","{{property_b_id}}"] }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 204', () => pm.response.to.have.status(204));"
