        "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{tenant_email}}\",\n  \"password\": \"password123\",\n  \"name\": \"Пётр Арендатор\",\n  \"role\": \"tenant\"\n}" }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 201', () => pm.response.to.have.status(201));",
        "pm.test('user role tenant', () => pm.expect(pm.response.json().user.role).to.eql('tenant'));"
      ]}}]
    },
