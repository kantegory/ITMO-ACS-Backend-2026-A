{
  "info": {
    "name": "Rental API (lab2 microservices)",
    "description": "Postman-коллекция для микросервисной версии (ЛР2 + ДЗ5). Адаптирована под изменённые контракты: id — строки, отдельная авторизация по 403/409, проверки снапшотов и системных сообщений из RabbitMQ.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080/api/v1" },
    { "key": "landlord_email", "value": "" },
    { "key": "landlord_b_email", "value": "" },
    { "key": "tenant_email", "value": "" },
    { "key": "tenant_b_email", "value": "" },
    { "key": "landlord_token", "value": "" },
    { "key": "landlord_b_token", "value": "" },
    { "key": "tenant_token", "value": "" },
    { "key": "tenant_b_token", "value": "" },
    { "key": "property_id", "value": "" },
    { "key": "property_b_id", "value": "" },
    { "key": "rental_id", "value": "" },
    { "key": "rental_b_id", "value": "" },
    { "key": "original_title", "value": "Уютная квартира в центре" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('landlord_email')) {",
          "  const stamp = Date.now();",
          "  pm.collectionVariables.set('landlord_email', `landlord_a_${stamp}@test.com`);",
          "  pm.collectionVariables.set('landlord_b_email', `landlord_b_${stamp}@test.com`);",
          "  pm.collectionVariables.set('tenant_email', `tenant_a_${stamp}@test.com`);",
          "  pm.collectionVariables.set('tenant_b_email', `tenant_b_${stamp}@test.com`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01. Register landlord A",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] },
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{landlord_email}}\",\n  \"password\": \"password123\",\n  \"name\": \"Иван Арендодатель\",\n  \"role\": \"landlord\"\n}" }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 201', () => pm.response.to.have.status(201));",
        "const j = pm.response.json();",
        "pm.test('token returned', () => pm.expect(j.access_token).to.be.a('string').and.not.empty);",
        "pm.test('user role landlord', () => pm.expect(j.user.role).to.eql('landlord'));",
        "pm.test('user.id is string (bigint-safe)', () => pm.expect(j.user.id).to.be.a('string'));",
        "pm.collectionVariables.set('landlord_token', j.access_token);"
      ]}}]
    },
    {
      "name": "02. Register landlord B",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] },
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{landlord_b_email}}\",\n  \"password\": \"password123\",\n  \"name\": \"Сергей Второй\",\n  \"role\": \"landlord\"\n}" }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 201', () => pm.response.to.have.status(201));",
        "pm.collectionVariables.set('landlord_b_token', pm.response.json().access_token);"
      ]}}]
    },
    {
      "name": "03. Register tenant 1",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
