        "body": { "mode": "raw", "raw": "{not-a-json" }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
        "pm.test('status 400 not 500', () => pm.response.to.have.status(400));",
        "pm.test('error bad_request', () => pm.expect(pm.response.json().error).to.eql('bad_request'));"
      ]}}]
    },
