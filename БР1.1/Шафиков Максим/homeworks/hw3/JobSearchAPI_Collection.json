				{
					"name": "9. Поиск вакансий с фильтром (format=remote)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"// Вспомогательная функция для извлечения массива вакансий из разных форматов ответа",
									"function extractVacancies(json) {",
									"    if (Array.isArray(json)) return json;",
									"    for (const key of ['items', 'vacancies', 'data', 'results']) {",
									"        if (json[key] && Array.isArray(json[key])) return json[key];",
									"    }",
									"    // Fallback: ищем любой массив в корне ответа",
									"    const arrVal = Object.values(json).find(v => Array.isArray(v));",
									"    return arrVal || [];",
									"}",
									"",
									"pm.test('Status 200 — запрос успешен', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Ответ содержит массив вакансий', function () {",
									"    const json = pm.response.json();",
									"    const vacancies = extractVacancies(json);",
									"    pm.expect(vacancies).to.be.an('array');",
									"    pm.collectionVariables.set('found_vacancy_id', vacancies.length > 0 ? vacancies[0].id : '');",
									"});",
									"",
									"pm.test('Найдена хотя бы одна вакансия', function () {",
									"    const json = pm.response.json();",
									"    const vacancies = extractVacancies(json);",
									"    pm.expect(vacancies.length).to.be.at.least(1, 'Фильтр должен вернуть хотя бы одну вакансию');",
									"});",
									"",
									"pm.test('Vacancy 1 (remote) присутствует в результатах', function () {",
									"    const json = pm.response.json();",
									"    const vacancies = extractVacancies(json);",
									"    const vacancy1Id = pm.collectionVariables.get('vacancy_id_1');",
									"    const ids = vacancies.map(v => v.id);",
									"    pm.expect(ids).to.include(vacancy1Id, 'Вакансия remote должна быть в результатах');",
									"    // Сохраняем id найденной вакансии для следующих шагов",
									"    pm.collectionVariables.set('found_vacancy_id', vacancy1Id);",
									"    console.log('[9] found_vacancy_id:', vacancy1Id);",
									"});",
									"",
									"pm.test('Vacancy 2 (office) отсутствует в результатах — фильтр работает', function () {",
									"    const json = pm.response.json();",
									"    const vacancies = extractVacancies(json);",
									"    const vacancy2Id = pm.collectionVariables.get('vacancy_id_2');",
									"    const ids = vacancies.map(v => v.id);",
									"    pm.expect(ids).to.not.include(vacancy2Id, 'Вакансия office НЕ должна быть в результатах');",
									"});",
									"",
									"pm.test('Все найденные вакансии имеют format=remote', function () {",
									"    const json = pm.response.json();",
									"    const vacancies = extractVacancies(json);",
									"    vacancies.forEach(function (v) {",
									"        pm.expect(v.format).to.equal('remote', 'Все вакансии в выдаче должны быть remote');",
									"    });",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/vacancies?format=remote&status=active&search_query={{run_id}}",
							"host": ["{{base_url}}"],
							"path": ["vacancies"],
							"query": [
								{ "key": "format",       "value": "remote" },
								{ "key": "status",       "value": "active" },
								{ "key": "search_query", "value": "{{run_id}}" }
							]
						}
					}
				},
				{
					"name": "10. Просмотр деталей вакансии",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200 — детали вакансии получены', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Ответ содержит обязательные поля VacancyDetail', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('id');",
									"    pm.expect(json).to.have.property('title');",
									"    pm.expect(json).to.have.property('format');",
									"    pm.expect(json).to.have.property('status');",
									"    pm.expect(json).to.have.property('created_at');",
									"    pm.expect(json).to.have.property('updated_at');",
									"});",
									"",
									"pm.test('id вакансии совпадает с ожидаемым', function () {",
									"    const json = pm.response.json();",
									"    const expectedId = pm.collectionVariables.get('found_vacancy_id');",
									"    pm.expect(json.id).to.equal(expectedId);",
									"});",
									"",
									"pm.test('Вакансия содержит детальные поля', function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('description');",
									"    if (json.skills !== undefined) {",
									"        pm.expect(json.skills).to.be.an('array')",
									"    }",
									"    if (json.company !== undefined) {",
									"        pm.expect(json.company).to.have.property('id');",
									"        pm.expect(json.company).to.have.property('name');",
									"    }",
									"});",
									"",
									"pm.test('Формат вакансии — remote', function () {",
									"    const json = pm.response.json();",
