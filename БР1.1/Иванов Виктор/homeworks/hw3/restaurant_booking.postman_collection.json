      "name": "1. Регистрация нового пользователя",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Статус 201 - пользователь создан', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Ответ содержит access_token', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('access_token');",
              "    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.test('Ответ содержит данные пользователя', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.user).to.have.property('id');",
              "    pm.expect(json.user.email).to.equal(pm.collectionVariables.get('test_email'));",
              "    pm.expect(json.user).to.not.have.property('password');",
              "});",
              "",
              "pm.test('token_type = bearer', function () {",
              "    pm.expect(pm.response.json().token_type).to.equal('bearer');",
              "});",
              "",
              "// Сохраняем токен для следующих запросов",
              "var json = pm.response.json();",
              "if (json.access_token) {",
              "    pm.collectionVariables.set('access_token', json.access_token);",
              "    console.log('Token saved:', json.access_token.substring(0, 20) + '...');",
              "}"
            ],
            "type": "text/javascript"
          }
        },
