{
  "name": "restaurant-booking-microservices",
  "version": "1.0.0",
  "private": true,
  "description": "ЛР2 + ДЗ5: микросервисы и RabbitMQ (система бронирования столиков)",
  "scripts": {
    "rabbit:up": "docker compose up -d",
    "rabbit:down": "docker compose down",
    "user": "ts-node -r tsconfig-paths/register src/user/index.ts",
    "restaurant": "ts-node -r tsconfig-paths/register src/restaurant/index.ts",
    "booking": "ts-node -r tsconfig-paths/register src/booking/index.ts",
    "notification": "ts-node -r tsconfig-paths/register src/notification/index.ts",
    "seed": "ts-node -r tsconfig-paths/register src/restaurant/seed.ts"
  },
  "dependencies": {
    "amqplib": "^0.10.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
