# Docker Compose (services/*/.env used by deploy/docker-compose.yml)
PORT=8081
DB_URL=postgres://auth:auth_password@postgres:5432/auth_db?sslmode=disable
JWT_SECRET=dev_secret_change_me
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

