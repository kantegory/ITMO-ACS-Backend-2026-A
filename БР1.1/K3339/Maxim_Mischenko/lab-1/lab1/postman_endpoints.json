						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"booking_id\": 1,\n  \"rating\": 5,\n  \"comment\": \"Great experience!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/restaurants/1/reviews",
							"host": ["{{baseUrl}}"],
							"path": ["restaurants", "1", "reviews"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
