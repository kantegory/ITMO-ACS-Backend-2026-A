{
	"info": {
		"_postman_id": "restaurant-booking-comprehensive-scenario",
		"name": "Restaurant Booking - Comprehensive Scenario",
		"description": "Comprehensive end-to-end scenario: register new user, login, browse restaurants, filter, view details, check tables, create booking, view bookings, leave review.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Comprehensive Scenario",
			"description": "Run this folder in order to simulate a complete user journey.",
			"item": [
				{
					"name": "1. Register new user",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{$timestamp}}@example.com\",\n  \"password\": \"password123\",\n  \"full_name\": \"Test User\",\n  \"phone\": \"+79161234567\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Registration successful\", function () {",
									"    pm.response.to.have.status(201);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.collectionVariables.set(\"user_id\", jsonData.id);",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "2. Login to get token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{$timestamp}}@example.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Login successful\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('access_token');",
									"    pm.collectionVariables.set(\"access_token\", jsonData.access_token);",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "3. Get cuisines (to filter)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/cuisines",
							"host": ["{{baseUrl}}"],
							"path": ["cuisines"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Cuisines retrieved\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"    if (jsonData.length > 0) {",
									"        pm.collectionVariables.set(\"cuisine_id\", jsonData[0].id);",
									"    }",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "4. Browse restaurants with filters",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/restaurants?city=Москва&cuisine_id={{cuisine_id}}&min_price=500&max_price=3000&sort_by=rating_desc&limit=5",
							"host": ["{{baseUrl}}"],
							"path": ["restaurants"],
							"query": [
								{
									"key": "city",
									"value": "Москва"
								},
								{
									"key": "cuisine_id",
									"value": "{{cuisine_id}}"
								},
								{
									"key": "min_price",
									"value": "500"
								},
								{
									"key": "max_price",
									"value": "3000"
								},
								{
									"key": "sort_by",
									"value": "rating_desc"
								},
								{
									"key": "limit",
									"value": "5"
								}
							]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Restaurants retrieved\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('items');",
									"    pm.expect(jsonData.items).to.be.an('array');",
									"    if (jsonData.items.length > 0) {",
									"        pm.collectionVariables.set(\"restaurant_id\", jsonData.items[0].id);",
									"    }",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "5. View restaurant details",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/restaurants/{{restaurant_id}}",
							"host": ["{{baseUrl}}"],
							"path": ["restaurants", "{{restaurant_id}}"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Restaurant details retrieved\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData.id).to.equal(pm.collectionVariables.get('restaurant_id'));",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "6. Get available tables",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/restaurants/{{restaurant_id}}/tables?capacity=4&date={{future_date}}",
							"host": ["{{baseUrl}}"],
							"path": ["restaurants", "{{restaurant_id}}", "tables"],
							"query": [
								{
									"key": "capacity",
									"value": "4"
								},
								{
									"key": "date",
									"value": "{{future_date}}"
								}
							]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Tables retrieved\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"    if (jsonData.length > 0) {",
									"        pm.collectionVariables.set(\"table_id\", jsonData[0].id);",
									"    }",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "7. Create booking",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"restaurant_id\": {{restaurant_id}},\n  \"table_id\": {{table_id}},\n  \"booking_date\": \"{{future_date}}\",\n  \"start_time\": \"19:00\",\n  \"end_time\": \"21:00\",\n  \"guests_count\": 4,\n  \"comment\": \"Booking from comprehensive scenario\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/bookings",
							"host": ["{{baseUrl}}"],
							"path": ["bookings"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Booking created\", function () {",
									"    pm.response.to.have.status(201);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.collectionVariables.set(\"booking_id\", jsonData.id);",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "8. View my bookings",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/bookings",
							"host": ["{{baseUrl}}"],
							"path": ["bookings"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Bookings list retrieved\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('items');",
									"    pm.expect(jsonData.items).to.be.an('array');",
									"    var found = false;",
									"    jsonData.items.forEach(function(item) {",
									"        if (item.id === parseInt(pm.collectionVariables.get('booking_id'))) {",
									"            found = true;",
									"        }",
									"    });",
									"    pm.expect(found).to.be.true;",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "9. Leave a review (requires booking completed status - simulate by updating status)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"booking_id\": {{booking_id}},\n  \"rating\": 5,\n  \"comment\": \"Great experience from comprehensive scenario!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/restaurants/{{restaurant_id}}/reviews",
							"host": ["{{baseUrl}}"],
							"path": ["restaurants", "{{restaurant_id}}", "reviews"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Review created (or appropriate status)\", function () {",
									"    // The review may fail if booking status is not 'completed', but we test anyway",
									"    pm.expect(pm.response.code).to.be.oneOf([201, 403, 400]);",
									"});"
								]
							}
						}
					]
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000/api/v1"
		},
		{
			"key": "access_token",
			"value": ""
		},
		{
			"key": "user_id",
			"value": ""
		},
		{
			"key": "cuisine_id",
			"value": "1"
		},
		{
			"key": "restaurant_id",
			"value": "1"
		},
		{
			"key": "table_id",
			"value": "1"
		},
		{
			"key": "booking_id",
			"value": ""
		},
		{
			"key": "future_date",
			"value": "2024-12-31"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"exec": [
					"// Generate a unique email using timestamp",
					"const timestamp = new Date().getTime();",
					"pm.collectionVariables.set(\"$timestamp\", timestamp);",
					"// Set future date to tomorrow",
					"const tomorrow = new Date();",
					"tomorrow.setDate(tomorrow.getDate() + 1);",
					"const formatted = tomorrow.toISOString().split('T')[0];",
					"pm.collectionVariables.set(\"future_date\", formatted);"
				]
			}
		}
	]
}