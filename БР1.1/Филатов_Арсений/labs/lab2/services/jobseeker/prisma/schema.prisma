generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model JobSeekerProfile {
  userId    Int    @id
  firstName String
  lastName  String
  phone     String?
  city      String?
  bio       String?
}

model Resume {
  id             Int                 @id @default(autoincrement())
  userId         Int
  title          String
  summary        String?
  isPublic       Boolean             @default(false)
  updatedAt      DateTime            @updatedAt
  education      ResumeEducation[]
  workExperience ResumeWorkExperience[]
  skills         ResumeSkill[]
}

model ResumeEducation {
  id          Int     @id @default(autoincrement())
  resumeId    Int
  institution String
  degree      String?
  yearFrom    Int?
  yearTo      Int?
  resume      Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ResumeWorkExperience {
  id          Int     @id @default(autoincrement())
  resumeId    Int
  companyName String
  position    String
  description String?
  dateFrom    String?
  dateTo      String?
  resume      Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ResumeSkill {
  resumeId Int
  skillId  Int
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@id([resumeId, skillId])
}
