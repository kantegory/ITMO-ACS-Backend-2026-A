# Скопируйте в .env. Prisma читает именно DATABASE_URL (не DATABASE_URL_APPLICATION).
PORT=3005
DATABASE_URL="postgresql://lab1_user:lab1_pass@localhost:5432/lab2_application?schema=public"

JWT_SECRET="replace-with-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN=3600

INTERNAL_SECRET="replace-internal-service-secret-min-16-chars"
EMPLOYER_SERVICE_URL=http://127.0.0.1:3004
JOBSEEKER_SERVICE_URL=http://127.0.0.1:3003

# Опционально для prisma/seed.ts
# SEED_VACANCY_ID=1
# SEED_RESUME_ID=1
# SEED_CANDIDATE_USER_ID=1
