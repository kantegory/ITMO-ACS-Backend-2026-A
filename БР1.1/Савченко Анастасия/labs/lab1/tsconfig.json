// Это конфигурация компилятора TypeScript. Он говорит, как превращать .ts файлы в .js файлы, куда их класть, какие правила использовать и какие файлы включать или исключать из компиляции.

{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs", // модульная система (для Node.js)
    "outDir": "./dist",  // папка для скомпилированных файлов
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "experimentalDecorators": true, // обязательны для TypeORM без них декораторы не будут работать
    "emitDecoratorMetadata": true, // нужно для TypeORM (сохраняет типы)
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"], // какие файлы компилировать
  "exclude": ["node_modules"] // что исключить
}

