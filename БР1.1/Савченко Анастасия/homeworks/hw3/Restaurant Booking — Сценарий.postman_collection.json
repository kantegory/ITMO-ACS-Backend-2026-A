    {
      "name": "5. Поиск ресторанов — Итальянская, СПб, mid",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Рестораны найдены\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.data).to.be.an(\"array\");\r",
              "    pm.expect(jsonData.data.length).to.be.at.least(1);\r",
              "    \r",
              "    // проверяем фильтры\r",
              "    jsonData.data.forEach(function(r) {\r",
              "        pm.expect(r.city_name).to.eql(\"Санкт-Петербург\");\r",
              "        pm.expect(r.price_tier).to.eql(\"mid\");\r",
              "        var names = r.cuisines.map(function(c) { return c.cuisine_name; });\r",
              "        pm.expect(names).to.include(\"Итальянская\");\r",
              "    });\r",
              "    \r",
              "    // сохраняем ID первого ресторана\r",
              "    pm.collectionVariables.set(\"restaurant_id\", jsonData.data[0].restaurant_id);\r",
              "    console.log(\"Ресторан ID:\", jsonData.data[0].restaurant_id, jsonData.data[0].name);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
