    {
      "name": "Auth",
      "item": [
        {
          "name": "Register applicant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.environment.set('token', json.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"applicant@itmo.ru\",\n  \"password\": \"password123\",\n  \"firstName\": \"Daniil\",\n  \"lastName\": \"Gelm\",\n  \"role\": \"applicant\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Register employer",
          "event": [
            {
              "listen": "test",
              "script": {
