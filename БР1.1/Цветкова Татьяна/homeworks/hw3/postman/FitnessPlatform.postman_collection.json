              "  pm.expect(pm.response.json().error.toLowerCase()).to.match(/token|unauthorized|missing/);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "18. Создание тренировки обычным user — 403 Forbidden",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/workouts", "host": ["{{baseUrl}}"], "path": ["workouts"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Попытка от user\",\n  \"description\": \"Должно быть запрещено\",\n  \"videoUrl\": \"https://example.com/v.mp4\",\n  \"type\": \"cardio\",\n  \"level\": \"beginner\",\n  \"durationMinutes\": 15\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Статус 403 Forbidden (роль user)', () => pm.response.to.have.status(403));",
              "pm.test('Возвращён error', () => pm.expect(pm.response.json()).to.have.property('error'));"
            ]
          }
        }
      ]
    }
  ]
}
