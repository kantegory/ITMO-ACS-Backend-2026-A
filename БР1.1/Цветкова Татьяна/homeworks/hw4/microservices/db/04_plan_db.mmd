        int workout_duration_min "денормализация"
        text workout_type "денормализация"
        int day_offset
        int order_index
        boolean completed
        text notes
        boolean workout_is_stale "true после workout.deleted"
    }

    PROCESSED_EVENTS {
        uuid event_id PK "дедупликация workout.* и user.deleted"
        timestamptz processed_at
    }

