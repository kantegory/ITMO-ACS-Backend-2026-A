        date start_date
        date end_date
        boolean is_active
        timestamptz created_at
        timestamptz updated_at
    }

    PLAN_ITEMS {
        uuid id PK
        uuid plan_id FK
        uuid workout_id "ссылается на catalog.workouts (логически)"
