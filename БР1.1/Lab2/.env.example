# Common HTTP settings
APP_HOST=localhost
APP_PROTOCOL=http
APP_API_PREFIX=/api/v1

# Public entrypoint
GATEWAY_PORT=8000

# Microservice ports
AUTH_SERVICE_PORT=8001
RECIPE_SERVICE_PORT=8002
INTERACTION_SERVICE_PORT=8003

# Service URLs used by the gateway and service-to-service clients
AUTH_SERVICE_URL=http://localhost:8001
RECIPE_SERVICE_URL=http://localhost:8002
INTERACTION_SERVICE_URL=http://localhost:8003

# End-user JWT
JWT_SECRET_KEY=change-me-user-jwt-secret
JWT_TOKEN_TYPE=Bearer
JWT_ACCESS_TOKEN_LIFETIME=86400

# Internal service-to-service JWT
SERVICE_JWT_SECRET=change-me-service-jwt-secret
SERVICE_TOKEN_LIFETIME=300

# Auth Service DB
AUTH_DB_HOST=localhost
AUTH_DB_PORT=15433
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_db
AUTH_DB_PASSWORD=auth_db

# Recipe Service DB
RECIPE_DB_HOST=localhost
RECIPE_DB_PORT=15434
RECIPE_DB_NAME=recipe_db
RECIPE_DB_USER=recipe_db
RECIPE_DB_PASSWORD=recipe_db

# Interaction Service DB
INTERACTION_DB_HOST=localhost
INTERACTION_DB_PORT=15435
INTERACTION_DB_NAME=interaction_db
INTERACTION_DB_USER=interaction_db
INTERACTION_DB_PASSWORD=interaction_db
