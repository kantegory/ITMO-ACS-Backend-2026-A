{
  "name": "recipe-platform-lab2-microservices",
  "version": "1.0.0",
  "description": "Lab2 microservice split for Recipe Sharing Platform",
  "main": "dist/api-gateway/app.js",
  "scripts": {
    "build": "npx tsc",
    "dev:gateway": "npx ts-node-dev --respawn --transpile-only --exit-child -r dotenv/config src/api-gateway/app.ts dotenv_config_path=.env",
    "dev:auth": "npx ts-node-dev --respawn --transpile-only --exit-child -r dotenv/config src/auth-service/app.ts dotenv_config_path=.env",
    "dev:recipe": "npx ts-node-dev --respawn --transpile-only --exit-child -r dotenv/config src/recipe-service/app.ts dotenv_config_path=.env",
    "dev:interaction": "npx ts-node-dev --respawn --transpile-only --exit-child -r dotenv/config src/interaction-service/app.ts dotenv_config_path=.env",
    "start:gateway": "node dist/api-gateway/app.js",
    "start:auth": "node dist/auth-service/app.js",
    "start:recipe": "node dist/recipe-service/app.js",
    "start:interaction": "node dist/interaction-service/app.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "amqplib": "^2.0.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.14.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.21"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
