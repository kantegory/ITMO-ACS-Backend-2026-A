POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

JWT_SECRET=dev-secret-change-me
JWT_EXPIRES=24h

AUTH_DB_DSN=postgres://postgres:postgres@auth-db:5432/auth_db?sslmode=disable
CATALOG_DB_DSN=postgres://postgres:postgres@catalog-db:5432/catalog_db?sslmode=disable
BOOKING_DB_DSN=postgres://postgres:postgres@booking-db:5432/booking_db?sslmode=disable

AUTH_HTTP_ADDR=:8081
CATALOG_HTTP_ADDR=:8082
BOOKING_HTTP_ADDR=:8083

AUTH_SERVICE_URL=http://auth-service:8081
CATALOG_SERVICE_URL=http://catalog-service:8082
