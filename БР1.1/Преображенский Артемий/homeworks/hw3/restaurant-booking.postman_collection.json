{
  "info": {
    "name": "Restaurant Booking API - Main Flow",
    "description": "Комплексный сценарий по основному процессу приложения бронирования столиков: регистрация -> вход -> профиль -> список ресторанов -> фильтрация -> просмотр ресторана -> меню -> отзывы -> столики -> проверка доступности -> бронирование -> список бронирований -> просмотр бронирования -> отмена -> проверка отмены.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080/api" },
    { "key": "email", "value": "postman@example.com" },
    { "key": "password", "value": "Password123!" },
    { "key": "full_name", "value": "Artemiy Preobrazhenskiy" },
    { "key": "phone", "value": "+79990000000" },
    { "key": "token", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "registered", "value": "0" },
    { "key": "restaurant_name", "value": "" },
    { "key": "restaurant_id", "value": "" },
    { "key": "restaurant_city", "value": "" },
    { "key": "restaurant_cuisine_type", "value": "" },
    { "key": "table_id", "value": "" },
    { "key": "menu_item_id", "value": "" },
    { "key": "review_id", "value": "" },
    { "key": "booking_id", "value": "" },
    { "key": "booking_date", "value": "" },
    { "key": "start_time", "value": "18:00:00" },
    { "key": "end_time", "value": "20:00:00" },
    { "key": "guests_count", "value": "2" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('restaurant_name')) {",
          "  pm.collectionVariables.set('restaurant_name', `Postman Restaurant ${Date.now()}`);",
          "}",
          "if (!pm.collectionVariables.get('booking_date')) {",
          "  const d = new Date();",
          "  d.setDate(d.getDate() + 14);",
          "  const iso = d.toISOString().slice(0, 10);",
          "  pm.collectionVariables.set('booking_date', iso);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01. Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  const body = pm.response.json();",
              "  pm.collectionVariables.set('token', body.token);",
              "  pm.collectionVariables.set('user_id', body.user.id);",
              "  pm.collectionVariables.set('registered', '1');",
              "  pm.test('login ok', () => pm.response.to.have.status(200));",
              "  postman.setNextRequest('03. Profile');",
              "} else {",
              "  pm.test('login needs register', () => pm.response.to.have.status(401));",
              "  postman.setNextRequest('02. Register');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "02. Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"full_name\": \"{{full_name}}\",\n  \"phone\": \"{{phone}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 201) {",
              "  pm.test('register ok', () => pm.response.to.have.status(201));",
              "  pm.collectionVariables.set('registered', '1');",
              "  postman.setNextRequest('01. Login');",
              "} else {",
              "  pm.test('user exists', () => pm.response.to.have.status(409));",
              "  postman.setNextRequest('01. Login');",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "03. Profile",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('User.id совпадает', () => pm.expect(body.User.id).to.eql(pm.collectionVariables.get('user_id')));",
              "pm.test('email совпадает', () => pm.expect(body.User.email).to.eql(pm.collectionVariables.get('email')));"
            ]
          }
        }
      ]
    },
    {
      "name": "04. Create restaurant",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{base_url}}/restaurants", "host": ["{{base_url}}"], "path": ["restaurants"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{restaurant_name}}\",\n  \"description\": \"Test restaurant\",\n  \"city\": \"Saint Petersburg\",\n  \"address\": \"Test address\",\n  \"cuisine_type\": \"italian\",\n  \"price_category\": \"medium\",\n  \"photos\": []\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('restaurant_id', body.restaurant.id);",
              "pm.collectionVariables.set('restaurant_city', body.restaurant.city);",
              "pm.collectionVariables.set('restaurant_cuisine_type', body.restaurant.cuisine_type);"
            ]
          }
        }
      ]
    },
    {
      "name": "05. List restaurants",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{base_url}}/restaurants", "host": ["{{base_url}}"], "path": ["restaurants"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('restaurants — массив', () => pm.expect(body.restaurants).to.be.an('array'));",
              "pm.test('созданный ресторан есть в списке', () => {",
              "  const id = pm.collectionVariables.get('restaurant_id');",
              "  pm.expect(body.restaurants.map(r => r.id)).to.include(id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "05. Filter restaurants by city and cuisine",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/restaurants?city={{restaurant_city}}&cuisine_type={{restaurant_cuisine_type}}",
          "host": ["{{base_url}}"],
          "path": ["restaurants"],
          "query": [
            { "key": "city", "value": "{{restaurant_city}}" },
            { "key": "cuisine_type", "value": "{{restaurant_cuisine_type}}" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('restaurants — массив', () => pm.expect(body.restaurants).to.be.an('array'));",
              "const city = pm.collectionVariables.get('restaurant_city');",
              "const cuisine = pm.collectionVariables.get('restaurant_cuisine_type');",
              "pm.test('фильтр по city работает', () => body.restaurants.forEach(r => pm.expect(r.city).to.eql(city)));",
              "pm.test('фильтр по cuisine_type работает', () => body.restaurants.forEach(r => pm.expect(r.cuisine_type).to.eql(cuisine)));",
              "pm.test('выбранный ресторан присутствует в результатах', () => {",
              "  const id = pm.collectionVariables.get('restaurant_id');",
              "  pm.expect(body.restaurants.map(r => r.id)).to.include(id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "06. Get restaurant details",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/restaurants/{{restaurant_id}}",
          "host": ["{{base_url}}"],
          "path": ["restaurants", "{{restaurant_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('id совпадает', () => pm.expect(body.restaurant.id).to.eql(pm.collectionVariables.get('restaurant_id')));",
              "pm.test('описание присутствует', () => pm.expect(body.restaurant.description).to.be.a('string'));"
            ]
          }
        }
      ]
    },
