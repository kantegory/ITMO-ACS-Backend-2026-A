erDiagram
    USER {
        int user_id PK
        string name
        string email
        string phone
        string password_hash
        datetime created_at
    }

    RESTAURANT {
        int restaurant_id PK
        string name
        string description
        string address
        string price_level
        string opening_time
        string closing_time
        string phone
        datetime created_at
    }

    CUISINE {
        int cuisine_id PK
        string name
    }

    RESTAURANT_CUISINE {
        int restaurant_id FK
        int cuisine_id FK
    }

    RESTAURANT_TABLE {
        int table_id PK
        int restaurant_id FK
        int table_number
        int capacity
        string status
    }

    RESERVATION {
        int reservation_id PK
        int user_id FK
        int table_id FK
        date reservation_date
        time reservation_time
        int guests_count
        string status
        datetime created_at
    }

    REVIEW {
        int review_id PK
        int user_id FK
        int restaurant_id FK
        int rating
        string comment
        datetime created_at
    }

    RESTAURANT_PHOTO {
        int photo_id PK
        int restaurant_id FK
        string photo_url
    }

    MENU_ITEM {
        int menu_item_id PK
        int restaurant_id FK
        string name
        string description
        decimal price
        string category
    }

    USER ||--o{ RESERVATION : makes
    USER ||--o{ REVIEW : writes
    RESTAURANT ||--o{ RESTAURANT_TABLE : has
    RESTAURANT ||--o{ REVIEW : receives
    RESTAURANT ||--o{ RESTAURANT_PHOTO : contains
    RESTAURANT ||--o{ MENU_ITEM : offers
    RESTAURANT ||--o{ RESTAURANT_CUISINE : includes
    CUISINE ||--o{ RESTAURANT_CUISINE : defines
    RESTAURANT_TABLE ||--o{ RESERVATION : booked_in