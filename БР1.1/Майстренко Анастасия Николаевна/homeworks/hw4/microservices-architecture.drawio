        <!-- API Gateway -->
        <mxCell id="gw" value="API Gateway&#10;(маршрутизация, проверка JWT, агрегация)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
