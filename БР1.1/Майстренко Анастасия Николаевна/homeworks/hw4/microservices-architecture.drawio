        <mxCell id="e_book_db" style="endArrow=classic;html=1;" edge="1" parent="1" source="svc_book" target="db_book"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_msg_db" style="endArrow=classic;html=1;" edge="1" parent="1" source="svc_msg" target="db_msg"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- internal sync REST between services (dashed blue) -->
        <mxCell id="e_book_cat" value="GET /internal/properties/{id}" style="endArrow=classic;html=1;dashed=1;strokeColor=#6c8ebf;fontSize=9;exitX=0;exitY=0.3;entryX=1;entryY=0.3;" edge="1" parent="1" source="svc_book" target="svc_cat"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_book_id" value="GET /internal/users/{id}" style="endArrow=classic;html=1;dashed=1;strokeColor=#6c8ebf;fontSize=9;exitX=0;exitY=0.7;entryX=1;entryY=0.7;" edge="1" parent="1" source="svc_book" target="svc_id"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_msg_id" value="GET /internal/users/{id}" style="endArrow=classic;html=1;dashed=1;strokeColor=#6c8ebf;fontSize=9;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="svc_msg" target="svc_id"><mxGeometry relative="1" as="geometry">
