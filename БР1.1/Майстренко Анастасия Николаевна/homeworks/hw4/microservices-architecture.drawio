        <mxCell id="e_cat_br" style="endArrow=open;html=1;dashed=1;dashPattern=1 2;strokeColor=#d79b00;" edge="1" parent="1" source="db_cat" target="broker"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_book_br" style="endArrow=open;html=1;dashed=1;dashPattern=1 2;strokeColor=#d79b00;" edge="1" parent="1" source="db_book" target="broker"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e_br_msg" value="событие" style="endArrow=open;html=1;dashed=1;dashPattern=1 2;strokeColor=#d79b00;fontSize=9;" edge="1" parent="1" source="broker" target="db_msg"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Legend -->
        <mxCell id="leg" value="Условные обозначения:&#10;— сплошная: синхронный REST&#10;— синяя пунктирная: межсервисный REST (/internal)&#10;— оранжевая точечная: асинхронные события через брокер" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;spacingLeft=6;spacingTop=4;" vertex="1" parent="1">
