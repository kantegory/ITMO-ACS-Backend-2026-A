        </mxCell>

        <!-- Services -->
        <mxCell id="svc_id" value="Identity Service&#10;(аутентификация,&#10;пользователи)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="270" width="200" height="64" as="geometry"/>
        </mxCell>
        <mxCell id="svc_cat" value="Catalog Service&#10;(объекты, фото,&#10;удобства, избранное)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="270" width="200" height="64" as="geometry"/>
        </mxCell>
        <mxCell id="svc_book" value="Booking Service&#10;(сделки, отзывы)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="270" width="200" height="64" as="geometry"/>
        </mxCell>
        <mxCell id="svc_msg" value="Messaging Service&#10;(диалоги, сообщения)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="270" width="200" height="64" as="geometry"/>
        </mxCell>

        <!-- Databases (database-per-service) -->
        <mxCell id="db_id" value="users_db&#10;User" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="390" width="120" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="db_cat" value="catalog_db&#10;Property, Photo,&#10;Amenity, Favorite" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="390" width="120" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="db_book" value="booking_db&#10;Booking, Review" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="390" width="120" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="db_msg" value="messaging_db&#10;Conversation,&#10;Message" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="390" width="120" height="80" as="geometry"/>
