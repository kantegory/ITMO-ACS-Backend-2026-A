        <!-- Message broker -->
        <mxCell id="broker" value="Брокер сообщений (RabbitMQ / Kafka) — асинхронные события: user.registered, property.updated, booking.confirmed, booking.completed" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
