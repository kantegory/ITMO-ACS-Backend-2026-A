        <mxCell id="e_cg" value="HTTPS / REST" style="endArrow=classic;html=1;fontSize=10;" edge="1" parent="1" source="client" target="gw">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Gateway -> services (REST) -->
        <mxCell id="e_g_id" style="endArrow=classic;html=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="gw" target="svc_id"><mxGeometry relative="1" as="geometry"/></mxCell>
