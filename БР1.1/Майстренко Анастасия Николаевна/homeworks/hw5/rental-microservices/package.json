{
  "name": "rental-microservices",
  "version": "1.0.0",
  "description": "Микросервисная реализация сервиса аренды недвижимости (ИТМО, ЛР2)",
  "license": "MIT",
  "scripts": {
    "identity": "tsx --env-file=.env services/identity/app.ts",
    "catalog": "tsx --env-file=.env services/catalog/app.ts",
    "booking": "tsx --env-file=.env services/booking/app.ts",
    "messaging": "tsx --env-file=.env services/messaging/app.ts",
    "gateway": "tsx --env-file=.env gateway/app.ts",
    "start:all": "concurrently -n identity,catalog,booking,messaging,gateway -c green,blue,magenta,cyan,yellow \"npm:identity\" \"npm:catalog\" \"npm:booking\" \"npm:messaging\" \"npm:gateway\""
  },
  "dependencies": {
    "amqplib": "^0.10.9",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.14.0",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "0.11.0",
    "typeorm": "^0.3.21"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "better-sqlite3": "^11.8.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
