              "",
              "pm.test(\"User created\", function () {",
              "    const data = pm.response.json();",
              "",
              "    pm.expect(data).to.have.property(\"id\");",
              "    pm.expect(data).to.have.property(\"username\");",
              "    pm.expect(data).to.have.property(\"email\");",
              "});"
