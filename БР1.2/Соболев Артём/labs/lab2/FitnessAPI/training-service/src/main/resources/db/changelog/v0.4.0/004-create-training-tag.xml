<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260408" author="artsobol">
        <createTable tableName="training_tag">
            <column name="training_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="tag_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="training_tag" columnNames="training_id, tag_id"
                       constraintName="pk_training_tag"/>

        <addForeignKeyConstraint baseTableName="training_tag"
                                 baseColumnNames="tag_id"
                                 constraintName="fk_training_tag_tag"
                                 referencedTableName="tag"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="training_tag"
                                 baseColumnNames="training_id"
                                 constraintName="fk_training_tag_training"
                                 referencedTableName="training"
                                 referencedColumnNames="id"/>

        <createIndex tableName="training_tag" indexName="idx_training_tag_training">
            <column name="training_id"/>
        </createIndex>

        <createIndex tableName="training_tag" indexName="idx_training_tag_tag">
            <column name="tag_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>