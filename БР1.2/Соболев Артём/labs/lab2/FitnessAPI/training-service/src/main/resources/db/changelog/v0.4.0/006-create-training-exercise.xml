<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260408" author="artsobol">
        <createTable tableName="training_exercise">
            <column name="id" type="bigserial">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_training_exercise"/>
            </column>
            <column name="training_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="exercise_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="order_index" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="training_exercise"
                                 baseColumnNames="exercise_id"
                                 constraintName="fk_training_exercise_exercise"
                                 referencedTableName="exercise"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="training_exercise"
                                 baseColumnNames="training_id"
                                 constraintName="fk_training_exercise_training"
                                 referencedTableName="training"
                                 referencedColumnNames="id"/>

        <createIndex tableName="training_exercise" indexName="idx_training_exercise_training">
            <column name="training_id"/>
        </createIndex>

        <createIndex tableName="training_exercise" indexName="idx_training_exercise_exercise">
            <column name="exercise_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>