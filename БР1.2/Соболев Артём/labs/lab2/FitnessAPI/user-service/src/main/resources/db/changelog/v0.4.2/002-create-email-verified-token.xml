<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260417-create-email-verified-token" author="artsobol">
        <createTable tableName="email_verified_token">
            <column name="id" type="bigserial" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_email_verified_token"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="token_hash" type="varchar(255)">
                <constraints nullable="false" unique="true"
                             uniqueConstraintName="uq_email_verified_token_token_hash"/>
            </column>
            <column name="expires_at" type="timestamptz">
                <constraints nullable="false"/>
            </column>
            <column name="revoked_at" type="timestamptz"/>
            <column name="used_at" type="timestamptz"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="email_verified_token"
                                 baseColumnNames="user_id"
                                 constraintName="fk_email_verified_token_user_id"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <createIndex tableName="email_verified_token" indexName="idx_email_verified_token_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
