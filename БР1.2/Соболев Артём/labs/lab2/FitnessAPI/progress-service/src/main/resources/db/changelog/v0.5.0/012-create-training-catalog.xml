<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260509-create-training-catalog" author="artsobol">
        <createTable tableName="training_catalog">
            <column name="id" type="bigint">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_training_catalog"/>
            </column>
            <column name="is_active" type="boolean">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="training_catalog_exercise">
            <column name="id" type="bigserial">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_training_catalog_exercise"/>
            </column>
            <column name="training_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="training_exercise_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="exercise_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="order_index" type="integer">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="training_catalog_exercise"
                baseColumnNames="training_id"
                referencedTableName="training_catalog"
                referencedColumnNames="id"
                constraintName="fk_training_catalog_exercise_training"/>

        <createIndex tableName="training_catalog_exercise" indexName="idx_training_catalog_exercise_training">
            <column name="training_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
