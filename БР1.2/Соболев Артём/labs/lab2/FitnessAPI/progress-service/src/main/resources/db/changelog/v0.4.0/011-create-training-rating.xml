<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260411-create-training-rating" author="artsobol">
        <createTable tableName="training_rating">
            <column name="training_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="rating" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="text"/>
            <column name="created_at" type="timestamptz">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="training_rating"
                       columnNames="training_id, user_id"
                       constraintName="pk_training_rating"/>

        <createIndex tableName="training_rating" indexName="idx_training_rating_training">
            <column name="training_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
