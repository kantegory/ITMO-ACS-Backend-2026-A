<configuration>
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="fitness-service"/>
    <property name="LOG_PATH" value="${LOG_PATH:-logs}"/>
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [${APP_NAME}] [requestId=%X{requestId:-} userId=%X{userId:-}] %logger{36} - %msg%n"/>
    <property name="CONSOLE_COLOR_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) %cyan([${APP_NAME}]) [requestId=%X{requestId:-} userId=%X{userId:-}] %cyan(%logger{36}) - %msg%n"/>

    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="CONSOLE_COLOR" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_COLOR_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <logger name="org.springframework" level="WARN"/>
    <logger name="org.hibernate" level="WARN"/>

    <springProfile name="local,dev">
        <logger name="io.github.artsobol" level="DEBUG"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE_COLOR"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <springProfile name="default">
        <logger name="io.github.artsobol" level="INFO"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE_COLOR"/>
        </root>
    </springProfile>

    <springProfile name="prod">
        <logger name="io.github.artsobol" level="INFO"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE_PLAIN"/>
        </root>
    </springProfile>
</configuration>
