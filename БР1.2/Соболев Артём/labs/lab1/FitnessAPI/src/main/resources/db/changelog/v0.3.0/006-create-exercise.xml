<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260409-create-exercise" author="artsobol">
        <createTable tableName="exercise">
            <column name="id" type="bigserial" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_exercise"/>
            </column>
            <column name="title" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(255)"/>
            <column name="muscle_group" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="training_level" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamptz">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="exercise_video">
            <column name="exercise_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="video_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="exercise_video"
                       columnNames="exercise_id, video_id"
                       constraintName="pk_exercise_video"/>

        <addForeignKeyConstraint baseTableName="exercise_video"
                                 baseColumnNames="exercise_id"
                                 constraintName="fk_exercise_video_exercise"
                                 referencedTableName="exercise"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="exercise_video"
                                 baseColumnNames="video_id"
                                 constraintName="fk_exercise_video_video"
                                 referencedTableName="video"
                                 referencedColumnNames="id"/>

        <createIndex tableName="exercise_video" indexName="idx_exercise_video_exercise">
            <column name="exercise_id"/>
        </createIndex>

        <createIndex tableName="exercise_video" indexName="idx_exercise_video_video">
            <column name="video_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
