<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260408" author="artsobol">
        <createTable tableName="training_type">
            <column name="training_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="type_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="training_type" columnNames="training_id, type_id"
                       constraintName="pk_training_type"/>

        <addForeignKeyConstraint baseTableName="training_type"
                                 baseColumnNames="type_id"
                                 constraintName="fk_training_type_type"
                                 referencedTableName="type"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="training_type"
                                 baseColumnNames="training_id"
                                 constraintName="fk_training_type_training"
                                 referencedTableName="training"
                                 referencedColumnNames="id"/>

        <createIndex tableName="training_type" indexName="idx_training_type_training">
            <column name="training_id"/>
        </createIndex>

        <createIndex tableName="training_type" indexName="idx_training_type_type">
            <column name="type_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>