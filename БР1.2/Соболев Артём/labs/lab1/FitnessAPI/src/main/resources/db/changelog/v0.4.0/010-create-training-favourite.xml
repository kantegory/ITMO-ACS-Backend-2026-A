<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260411-create-training-favourite" author="artsobol">
        <createTable tableName="training_favourite">
            <column name="training_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="training_favourite"
                       columnNames="training_id, user_id"
                       constraintName="pk_training_favourite"/>

        <addForeignKeyConstraint baseTableName="training_favourite"
                                 baseColumnNames="training_id"
                                 constraintName="fk_training_favourite_training"
                                 referencedTableName="training"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="training_favourite"
                                 baseColumnNames="user_id"
                                 constraintName="fk_training_favourite_user"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>

        <createIndex tableName="training_favourite" indexName="idx_training_favourite_user">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
