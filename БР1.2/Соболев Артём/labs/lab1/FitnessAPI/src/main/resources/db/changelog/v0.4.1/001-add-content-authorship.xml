<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260412-add-content-authorship-columns" author="artsobol">
        <addColumn tableName="article">
            <column name="author_id" type="bigint"/>
            <column name="last_modified_by" type="bigint"/>
        </addColumn>

        <addColumn tableName="exercise">
            <column name="author_id" type="bigint"/>
            <column name="last_modified_by" type="bigint"/>
        </addColumn>

        <addColumn tableName="training">
            <column name="author_id" type="bigint"/>
            <column name="last_modified_by" type="bigint"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="article"
                                 baseColumnNames="author_id"
                                 constraintName="fk_article_author"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="article"
                                 baseColumnNames="last_modified_by"
                                 constraintName="fk_article_last_modified_by"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="exercise"
                                 baseColumnNames="author_id"
                                 constraintName="fk_exercise_author"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="exercise"
                                 baseColumnNames="last_modified_by"
                                 constraintName="fk_exercise_last_modified_by"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="training"
                                 baseColumnNames="author_id"
                                 constraintName="fk_training_author"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="training"
                                 baseColumnNames="last_modified_by"
                                 constraintName="fk_training_last_modified_by"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>

        <createIndex tableName="article" indexName="idx_article_author_id">
            <column name="author_id"/>
        </createIndex>

        <createIndex tableName="exercise" indexName="idx_exercise_author_id">
            <column name="author_id"/>
        </createIndex>

        <createIndex tableName="training" indexName="idx_training_author_id">
            <column name="author_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
