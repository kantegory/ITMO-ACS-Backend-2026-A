<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260411-create-training-session-exercise" author="artsobol">
        <createTable tableName="training_session_exercise">
            <column name="id" type="bigserial">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_training_session_exercise"/>
            </column>
            <column name="training_session_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="training_exercise_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="exercise_status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="timestamptz"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="training_session_exercise"
                                 baseColumnNames="training_session_id"
                                 constraintName="fk_training_session_exercise_session"
                                 referencedTableName="training_session"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="training_session_exercise"
                                 baseColumnNames="training_exercise_id"
                                 constraintName="fk_training_session_exercise_training_exercise"
                                 referencedTableName="training_exercise"
                                 referencedColumnNames="id"/>

        <createIndex tableName="training_session_exercise" indexName="idx_training_session_exercise_session">
            <column name="training_session_id"/>
        </createIndex>

        <createIndex tableName="training_session_exercise" indexName="idx_training_session_exercise_training_exercise">
            <column name="training_exercise_id"/>
        </createIndex>

        <addUniqueConstraint tableName="training_session_exercise"
                             columnNames="training_session_id, training_exercise_id"
                             constraintName="uk_training_session_exercise_session_training_exercise"/>
    </changeSet>

</databaseChangeLog>
