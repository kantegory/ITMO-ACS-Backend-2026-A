<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260411-create-training-session" author="artsobol">
        <createTable tableName="training_session">
            <column name="id" type="bigserial">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_training_session"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="training_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="training_status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="timestamptz"/>
            <column name="completed_at" type="timestamptz"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="training_session"
                                 baseColumnNames="user_id"
                                 constraintName="fk_training_session_user"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="training_session"
                                 baseColumnNames="training_id"
                                 constraintName="fk_training_session_training"
                                 referencedTableName="training"
                                 referencedColumnNames="id"/>

        <createIndex tableName="training_session" indexName="idx_training_session_user">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="training_session" indexName="idx_training_session_training">
            <column name="training_id"/>
        </createIndex>

        <createIndex tableName="training_session" indexName="idx_training_session_user_training_status">
            <column name="user_id"/>
            <column name="training_id"/>
            <column name="training_status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
