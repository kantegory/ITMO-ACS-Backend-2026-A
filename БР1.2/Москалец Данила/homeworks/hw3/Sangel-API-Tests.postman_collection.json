  "item": [
    {
      "name": "01 Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('API is alive', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 Register Owner",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{password}}\",\n  \"first_name\": \"Owner\",\n  \"last_name\": \"Tester\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "auth", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Owner registered', function () {",
              "  pm.response.to.have.status(201);",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.email).to.eql(pm.collectionVariables.get('ownerEmail'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "03 Login Owner",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["{{apiPrefix}}", "auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Owner logged in', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.data.tokens.access_token).to.be.a('string');",
              "  pm.collectionVariables.set('ownerAccessToken', json.data.tokens.access_token);",
              "  pm.collectionVariables.set('ownerUserId', json.data.user.id);",
              "});"
            ]
          }
        }
      ]
    },
