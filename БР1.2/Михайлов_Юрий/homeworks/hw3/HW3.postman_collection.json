    {
      "name": "List Copy",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Status check",
              "pm.test(\"Status is 200 or 201\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "// 2. Valid JSON",
              "pm.test(\"Response is valid JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "// 3. Non-empty list",
              "pm.test(\"Response is a non-empty list\", function () {",
              "    const json = pm.response.json();",
              "    // Support both array response and { data: [...] } / { items: [...] } shapes",
              "    const list = Array.isArray(json) ? json : (json.data || json.items || json.results || []);",
              "    pm.expect(list).to.be.an(\"array\").that.is.not.empty;",
              "});",
              "",
              "// 4. City filter verification (only when city query param is present and not a placeholder)",
              "const cityParam = pm.request.url.query.get(\"city\");",
              "if (cityParam && cityParam !== \"string\" && cityParam.trim() !== \"\") {",
              "    pm.test(\"All returned items match the city filter: \" + cityParam, function () {",
              "        const json = pm.response.json();",
              "        const list = Array.isArray(json) ? json : (json.data || json.items || json.results || []);",
              "        list.forEach(function (item) {",
              "            // Check city on item directly or nested in location",
              "            const itemCity = item.city || (item.location && item.location.city);",
              "            pm.expect(itemCity).to.equal(cityParam);",
              "        });",
              "    });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
