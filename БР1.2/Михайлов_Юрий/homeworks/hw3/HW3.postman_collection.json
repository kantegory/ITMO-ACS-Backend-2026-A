      "name": "Login Owner",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Status check",
              "pm.test(\"Status is 200 or 201\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "// 2. Valid JSON",
              "pm.test(\"Response is valid JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "// 3. Capture tokens",
              "pm.test(\"Response contains accessToken\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property(\"token\");",
              "",
              "    const token = json.token;",
              "",
              "    // Always store to current_token",
              "    pm.collectionVariables.set(\"owner_token\", token); ",
              "",
              "    // Determine which role token to store based on request body email",
              "    try {",
              "        const reqBody = JSON.parse(pm.request.body.raw);",
              "        if (reqBody.email === \"user@example.com\") {",
              "            pm.collectionVariables.set(\"owner_token\", token);",
              "            console.log(\"Saved owner_token\");",
              "        } else if (reqBody.email === \"user11@example.com\") {",
              "            pm.collectionVariables.set(\"client_token\", token);",
              "            console.log(\"Saved client_token\");",
              "        }",
              "    } catch (e) {",
              "        console.warn(\"Could not parse request body to determine role:\", e);",
              "    }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
