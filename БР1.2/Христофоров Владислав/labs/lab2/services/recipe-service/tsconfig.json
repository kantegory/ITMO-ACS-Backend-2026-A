{
    "compilerOptions": {
        "target": "es2022",
        "module": "commonjs",
        "lib": ["es2022", "dom"],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "strictPropertyInitialization": false
    },
    "include": ["src/**/*"]
}
