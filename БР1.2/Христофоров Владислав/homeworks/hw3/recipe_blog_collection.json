{
    "info": {
        "_postman_id": "a1b2c3d4-e5f6-7890-1234-56789abcdef0",
        "name": "Recipe & Culinary Blog API - Основной сценарий",
        "description": "Комплексный User Journey: Регистрация -> Вход -> Заполнение профиля -> Создание рецепта -> Поиск -> Просмотр -> Сохранение в закладки -> Комментарий -> Лайк -> Публикация поста в блоге.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Регистрация нового повара",
            "event": [
                {
                    "listen": "prerequest",
                    "script": {
                        "exec": [
                            "const randomNum = Math.floor(Math.random() * 1000000);",
                            "pm.collectionVariables.set(\"testUsername\", \"chef_\" + randomNum);",
                            "pm.collectionVariables.set(\"testEmail\", \"chef_\" + randomNum + \"@test.com\");",
                            "pm.collectionVariables.set(\"testPassword\", \"securePassword123\");"
                        ],
                        "type": "text/javascript"
                    }
                },
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test(\"Статус код 201 Created\", function () {",
                            "    pm.response.to.have.status(201);",
                            "});",
                            "pm.test(\"Время ответа меньше 2000ms\", function () {",
                            "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                            "});",
                            "pm.test('Schema is valid (tv4)', function () {",
                            "    var schema = {",
                            "        \"type\": \"object\",",
                            "        \"properties\": {",
                            "            \"id\": { \"type\": \"string\" },",
                            "            \"username\": { \"type\": \"string\" },",
                            "            \"email\": { \"type\": \"string\" }",
                            "        },",
                            "        \"required\": [\"id\", \"username\", \"email\"]",
                            "    };",
                            "    pm.expect(tv4.validate(pm.response.json(), schema)).to.be.true;",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"username\": \"{{testUsername}}\",\n    \"email\": \"{{testEmail}}\",\n    \"password\": \"{{testPassword}}\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/auth/register",
                    "host": ["{{baseUrl}}"],
                    "path": ["auth", "register"]
                }
            }
        },
