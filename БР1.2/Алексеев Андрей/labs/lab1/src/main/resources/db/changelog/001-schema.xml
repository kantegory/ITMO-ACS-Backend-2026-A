        <addForeignKeyConstraint baseTableName="resume_education" baseColumnNames="resume_id"
                                 referencedTableName="resume" referencedColumnNames="id"
                                 constraintName="fk_resume_education_resume" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="resume_work_experience" baseColumnNames="resume_id"
                                 referencedTableName="resume" referencedColumnNames="id"
