            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="vacancy_skill">
            <column name="vacancy_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="skill_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="vacancy_skill" columnNames="vacancy_id, skill_id" constraintName="pk_vacancy_skill"/>

        <createTable tableName="vacancy_requirement">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_vacancy_requirement" nullable="false"/>
            </column>
            <column name="vacancy_id" type="UUID">
