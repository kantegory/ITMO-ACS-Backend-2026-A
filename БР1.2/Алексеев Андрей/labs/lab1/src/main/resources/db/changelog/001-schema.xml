        <addForeignKeyConstraint baseTableName="vacancy" baseColumnNames="company_id" referencedTableName="company"
                                 referencedColumnNames="id" constraintName="fk_vacancy_company"/>
        <addForeignKeyConstraint baseTableName="vacancy" baseColumnNames="industry_id" referencedTableName="industry"
