        <createTable tableName="resume_work_experience">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_resume_work_experience" nullable="false"/>
            </column>
            <column name="resume_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="company_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="position" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="city" type="VARCHAR(255)"/>
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="DATE"/>
            <column name="is_current" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="sort_order" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="vacancy">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_vacancy" nullable="false"/>
            </column>
            <column name="vacancy_assignment_id" type="UUID"/>
            <column name="company_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="industry_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="experience_level_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="salary_from" type="NUMERIC(12,2)"/>
            <column name="salary_to" type="NUMERIC(12,2)"/>
            <column name="city" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="employment_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="work_format" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
