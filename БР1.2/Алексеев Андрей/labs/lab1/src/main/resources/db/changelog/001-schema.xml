        <addForeignKeyConstraint baseTableName="employer_profile" baseColumnNames="company_id"
                                 referencedTableName="company" referencedColumnNames="id"
                                 constraintName="fk_employer_profile_company"/>
        <addForeignKeyConstraint baseTableName="resume" baseColumnNames="user_id" referencedTableName="user"
                                 referencedColumnNames="id" constraintName="fk_resume_user" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="resume_skill" baseColumnNames="resume_id" referencedTableName="resume"
                                 referencedColumnNames="id" constraintName="fk_resume_skill_resume" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="resume_skill" baseColumnNames="skill_id" referencedTableName="skill"
