            </column>
            <column name="resume_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="institution_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="degree" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="specialization" type="VARCHAR(255)"/>
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="DATE"/>
            <column name="is_current" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="sort_order" type="INTEGER">
                <constraints nullable="false"/>
