        <addForeignKeyConstraint baseTableName="vacancy" baseColumnNames="experience_level_id"
                                 referencedTableName="experience_level" referencedColumnNames="id"
                                 constraintName="fk_vacancy_experience_level"/>
        <addForeignKeyConstraint baseTableName="vacancy_skill" baseColumnNames="vacancy_id"
                                 referencedTableName="vacancy" referencedColumnNames="id"
                                 constraintName="fk_vacancy_skill_vacancy" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="vacancy_skill" baseColumnNames="skill_id" referencedTableName="skill"
                                 referencedColumnNames="id" constraintName="fk_vacancy_skill_skill"/>
        <addForeignKeyConstraint baseTableName="vacancy_requirement" baseColumnNames="vacancy_id"
                                 referencedTableName="vacancy" referencedColumnNames="id"
                                 constraintName="fk_vacancy_requirement_vacancy" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="vacancy_responsibility" baseColumnNames="vacancy_id"
                                 referencedTableName="vacancy" referencedColumnNames="id"
                                 constraintName="fk_vacancy_responsibility_vacancy" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="vacancy_benefit" baseColumnNames="vacancy_id"
                                 referencedTableName="vacancy" referencedColumnNames="id"
                                 constraintName="fk_vacancy_benefit_vacancy" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="vacancy_assignment" baseColumnNames="employer_profile_id"
                                 referencedTableName="employer_profile" referencedColumnNames="id"
                                 constraintName="fk_vacancy_assignment_employer_profile"/>
        <addForeignKeyConstraint baseTableName="vacancy_assignment" baseColumnNames="vacancy_id"
                                 referencedTableName="vacancy" referencedColumnNames="id"
                                 constraintName="fk_vacancy_assignment_vacancy" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="vacancy" baseColumnNames="vacancy_assignment_id"
                                 referencedTableName="vacancy_assignment" referencedColumnNames="id"
                                 constraintName="fk_vacancy_primary_assignment" onDelete="SET NULL"/>
        <addForeignKeyConstraint baseTableName="application" baseColumnNames="resume_id" referencedTableName="resume"
