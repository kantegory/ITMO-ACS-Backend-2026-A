        </createTable>

        <createTable tableName="vacancy_responsibility">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_vacancy_responsibility" nullable="false"/>
            </column>
            <column name="vacancy_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="vacancy_benefit">
            <column name="id" type="UUID">
                <constraints primaryKey="true" primaryKeyName="pk_vacancy_benefit" nullable="false"/>
            </column>
            <column name="vacancy_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INTEGER">
