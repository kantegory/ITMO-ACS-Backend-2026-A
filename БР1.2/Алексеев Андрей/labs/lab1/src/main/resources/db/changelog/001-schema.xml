    <changeSet id="004-add-constraints-and-indexes" author="pxdkxvan">
        <addUniqueConstraint tableName="vacancy_assignment" columnNames="vacancy_id, employer_profile_id"
                             constraintName="uk_vacancy_assignment_vacancy_employer_profile"/>
        <addUniqueConstraint tableName="application" columnNames="vacancy_id, resume_id"
                             constraintName="uk_application_vacancy_resume"/>
        <addUniqueConstraint tableName="favorite_vacancy" columnNames="user_id, vacancy_id"
                             constraintName="uk_favorite_vacancy_user_vacancy"/>
        <addUniqueConstraint tableName="resume_education" columnNames="resume_id, sort_order"
                             constraintName="uk_resume_education_resume_sort_order"/>
        <addUniqueConstraint tableName="resume_work_experience" columnNames="resume_id, sort_order"
                             constraintName="uk_resume_work_resume_sort_order"/>
        <addUniqueConstraint tableName="vacancy_requirement" columnNames="vacancy_id, sort_order"
                             constraintName="uk_vacancy_requirement_vacancy_sort_order"/>
        <addUniqueConstraint tableName="vacancy_responsibility" columnNames="vacancy_id, sort_order"
                             constraintName="uk_vacancy_responsibility_vacancy_sort_order"/>
        <addUniqueConstraint tableName="vacancy_benefit" columnNames="vacancy_id, sort_order"
                             constraintName="uk_vacancy_benefit_vacancy_sort_order"/>

        <createIndex tableName="user" indexName="idx_user_created_at">
            <column name="created_at"/>
        </createIndex>
        <createIndex tableName="employer_profile" indexName="idx_employer_profile_company_id">
            <column name="company_id"/>
        </createIndex>
        <createIndex tableName="resume" indexName="idx_resume_user_id">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="resume" indexName="idx_resume_status">
            <column name="status"/>
