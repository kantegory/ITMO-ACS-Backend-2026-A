  [Property Service], [User Service], [Получить профиль арендодателя для карточки объекта],
  [Rental Service], [Property Service], [Получить детали объекта при создании заявки на аренду],
  [Rental Service], [User Service], [Получить профиль арендатора],
  [Rental Service], [Property Service], [Обновить статус объекта при активации/завершении аренды],
