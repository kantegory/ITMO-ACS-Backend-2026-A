{
  "info": {
    "_postman_id": "b6b1e4b3-58b2-4d7f-8a9b-6f3f5c2a1f01",
    "name": "ДЗ3: Основной сценарий (аренда недвижимости)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Register Landlord",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const unique = Date.now();",
              "pm.collectionVariables.set('landlord_email', `landlord_${unique}@example.com`);",
              "pm.collectionVariables.set('landlord_password', 'Password123');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('landlord_id', data.user.id);",
              "pm.collectionVariables.set('landlord_token', data.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "accept", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"first_name\": \"Alexey\",\n  \"last_name\": \"Landlord\",\n  \"email\": \"{{landlord_email}}\",\n  \"password\": \"{{landlord_password}}\",\n  \"role\": \"landlord\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/auth/register"
      }
    },
    {
      "name": "02 - Register Renter",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const unique = Date.now() + 1;",
              "pm.collectionVariables.set('renter_email', `renter_${unique}@example.com`);",
              "pm.collectionVariables.set('renter_password', 'Password123');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('renter_id', data.user.id);",
              "pm.collectionVariables.set('renter_token', data.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "accept", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"first_name\": \"Alexey\",\n  \"last_name\": \"Renter\",\n  \"email\": \"{{renter_email}}\",\n  \"password\": \"{{renter_password}}\",\n  \"role\": \"renter\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/auth/register"
      }
    },
    {
      "name": "03 - Login Landlord",
      "event": [
