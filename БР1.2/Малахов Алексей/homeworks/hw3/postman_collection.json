        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{landlord_email}}\",\n  \"password\": \"{{landlord_password}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "04 - Login Renter",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('renter_token', data.access_token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "accept", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{renter_email}}\",\n  \"password\": \"{{renter_password}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/auth/login"
      }
    },
    {
      "name": "05 - Create Property (Landlord)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.collectionVariables.set('property_city', 'Санкт-Петербург');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('property_id', data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "accept", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{landlord_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"apartment\",\n  \"title\": \"Уютная квартира\",\n  \"description\": \"Квартира рядом с метро\",\n  \"street\": \"Невский проспект\",\n  \"building\": \"10\",\n  \"city\": \"{{property_city}}\",\n  \"country\": \"Россия\",\n  \"rooms\": 2,\n  \"area_sqm\": 45,\n  \"floor\": 3,\n  \"price_per_month\": 45000,\n  \"currency\": \"RUB\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/properties"
      }
    },
    {
      "name": "06 - List Properties",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "accept", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/properties"
      }
    },
    {
      "name": "07 - Filter Properties by City",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "const data = pm.response.json();",
              "pm.test('Has items', () => Array.isArray(data.items));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "accept", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/properties?city={{property_city}}"
      }
    },
    {
      "name": "08 - Get Property Details",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "accept", "value": "application/json" }
        ],
        "url": "{{baseUrl}}/properties/{{property_id}}"
      }
    },
    {
      "name": "09 - Start Conversation (Renter -> Landlord)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const data = pm.response.json();",
              "pm.collectionVariables.set('conversation_id', data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "accept", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{renter_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"recipient_id\": {{landlord_id}},\n  \"property_id\": {{property_id}},\n  \"content\": \"Здравствуйте! Интересует объект.\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": "{{baseUrl}}/conversations"
      }
    }
  ],
