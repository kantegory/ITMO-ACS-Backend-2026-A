# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=rental
DB_PASSWORD=rentalpass
DB_NAME=rental_db
DB_SSLMODE=disable

# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRE=24h
JWT_REFRESH_EXPIRE=168h

# File Upload
UPLOAD_DIR=./storage
MAX_UPLOAD_SIZE=10485760 # 10MB
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60s