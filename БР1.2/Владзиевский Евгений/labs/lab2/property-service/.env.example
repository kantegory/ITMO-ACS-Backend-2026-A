# Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=property
DB_PASSWORD=propertypass
DB_NAME=property_catalog_db
DB_SSLMODE=disable

# Server
SERVER_PORT=8082
SERVER_HOST=0.0.0.0

# Auth Service
AUTH_SERVICE_URL=http://localhost:8081
SERVICE_TOKEN=internal-service-token
JWT_SECRET=rental-microservices-secret-key

# File Upload
UPLOAD_DIR=./storage
MAX_UPLOAD_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif

# Logging
LOG_LEVEL=info
LOG_FORMAT=json