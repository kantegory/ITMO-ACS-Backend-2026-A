{
  "name": "restaurant-booking-lab2-microservices",
  "version": "1.0.0",
  "description": "Microservices implementation for restaurant booking API",
  "main": "dist/gateway/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm:dev:auth\" \"npm:dev:restaurants\" \"npm:dev:tables\" \"npm:dev:reservations\" \"npm:dev:gateway\"",
    "dev:auth": "ts-node-dev --respawn --transpile-only src/services/auth/index.ts",
    "dev:restaurants": "ts-node-dev --respawn --transpile-only src/services/restaurants/index.ts",
    "dev:tables": "ts-node-dev --respawn --transpile-only src/services/tables/index.ts",
    "dev:reservations": "ts-node-dev --respawn --transpile-only src/services/reservations/index.ts",
    "dev:gateway": "ts-node-dev --respawn --transpile-only src/gateway/index.ts",
    "build": "tsc",
    "start": "concurrently \"node dist/services/auth/index.js\" \"node dist/services/restaurants/index.js\" \"node dist/services/tables/index.js\" \"node dist/services/reservations/index.js\" \"node dist/gateway/index.js\""
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
