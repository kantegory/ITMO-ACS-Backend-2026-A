  "item": [
    {
      "name": "01 Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API is available', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response contains API message', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.message).to.include('Restaurant Booking API');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            ""
          ]
        }
      },
      "response": []
