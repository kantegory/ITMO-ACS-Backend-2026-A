    {
      "name": "05 List Restaurants",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Restaurants list is returned', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json()).to.be.an('array').that.is.not.empty;",
              "});",
              "",
              "const restaurants = pm.response.json();",
              "const selected = restaurants[Math.floor(Math.random() * restaurants.length)];",
              "pm.environment.set('restaurantId', selected.id);",
              "pm.environment.set('restaurantCity', selected.city);",
              "pm.environment.set('restaurantCuisine', selected.cuisines[0]);",
              "pm.environment.set('priceCategory', selected.price_category);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/restaurants",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "restaurants"
          ]
        }
      },
      "response": []
    },
    {
      "name": "06 Filter Restaurants",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Filtered restaurants are returned', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json()).to.be.an('array').that.is.not.empty;",
              "});",
              "",
              "pm.test('Filter by city and price category works', function () {",
              "  const restaurants = pm.response.json();",
              "  restaurants.forEach((restaurant) => {",
              "    pm.expect(restaurant.city).to.eql(pm.environment.get('restaurantCity'));",
              "    pm.expect(restaurant.price_category).to.eql(pm.environment.get('priceCategory'));",
              "  });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/restaurants?city={{restaurantCity}}&price_category={{priceCategory}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "restaurants"
          ],
          "query": [
            {
              "key": "city",
              "value": "{{restaurantCity}}"
            },
            {
              "key": "price_category",
              "value": "{{priceCategory}}"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "07 Get Selected Restaurant",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Restaurant card is returned', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Restaurant id matches selected item', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(String(json.id)).to.eql(String(pm.environment.get('restaurantId')));",
              "  pm.expect(json).to.have.property('tables');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/restaurants/{{restaurantId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "restaurants",
            "{{restaurantId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "08 Get Restaurant Tables",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Tables list is returned', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json()).to.be.an('array').that.is.not.empty;",
              "});",
              "",
              "const tables = pm.response.json().filter((table) => table.is_active);",
              "pm.expect(tables.length).to.be.above(0);",
              "const table = tables[0];",
              "pm.environment.set('tableId', table.id);",
              "pm.environment.set('guestCount', Math.min(2, table.capacity));",
              "const reservationDate = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString();",
              "pm.environment.set('reservationDateTime', reservationDate);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/restaurants/{{restaurantId}}/tables",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "restaurants",
            "{{restaurantId}}",
            "tables"
          ]
        }
      },
      "response": []
    },
    {
      "name": "09 Create Reservation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Reservation is created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Reservation has confirmed status', function () {",
              "  pm.expect(json.reservation.status).to.eql('confirmed');",
              "});",
              "",
              "pm.environment.set('reservationId', json.reservation.reservation_id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"restaurant_id\": {{restaurantId}},\n  \"table_id\": {{tableId}},\n  \"reservation_datetime\": \"{{reservationDateTime}}\",\n  \"guest_count\": {{guestCount}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/reservations",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reservations"
          ]
        }
      },
      "response": []
    },
    {
      "name": "10 Get My Reservations",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Reservations history is returned', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(pm.response.json()).to.be.an('array').that.is.not.empty;",
              "});",
              "",
              "pm.test('Created reservation is in history', function () {",
              "  const reservations = pm.response.json();",
              "  const found = reservations.some((reservation) => String(reservation.reservation_id) === String(pm.environment.get('reservationId')));",
              "  pm.expect(found).to.eql(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
