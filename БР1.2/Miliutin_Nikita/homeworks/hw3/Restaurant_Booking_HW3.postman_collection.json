    {
      "name": "02 Register User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const email = `postman_${Date.now()}@example.com`;",
              "pm.environment.set('userEmail', email);",
              "pm.environment.set('phone', '+79990000000');"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('User is registered', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Registration response contains token and user', function () {",
              "  pm.expect(json).to.have.property('token');",
              "  pm.expect(json.user.email).to.eql(pm.environment.get('userEmail'));",
              "});",
              "",
              "pm.environment.set('token', json.token);",
              "pm.environment.set('userId', json.user.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"full_name\": \"{{fullName}}\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{password}}\",\n  \"phone\": \"{{phone}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
