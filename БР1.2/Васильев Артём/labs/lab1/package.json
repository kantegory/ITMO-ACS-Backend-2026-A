{
  "name": "express-typeorm-boilerplate",
  "version": "1.0.0",
  "description": "A complex production-ready boilerplate based on express and typeorm",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node dist/app.js",
    "dev": "npx tsx --env-file=.env --watch  src/app.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate": "tsx --env-file=.env src/scripts/migrate.ts",
    "seed": "tsx --env-file=.env src/scripts/seed.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.14.0",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "0.11.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.21",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.10",
    "@types/swagger-ui-express": "^4.1.8",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
