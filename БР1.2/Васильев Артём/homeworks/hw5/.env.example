APP_HOST=localhost
APP_PORT=8000
APP_PROTOCOL=http
APP_API_PREFIX=/api/v1
APP_CONTROLLERS_PATH=/controllers/*.controller.ts

DB_HOST=localhost
DB_PORT=15432
DB_NAME=maindb
DB_USER=maindb
DB_PASSWORD=maindb
DB_ENTITIES=src/models/*.entity.ts
DB_SUBSCRIBERS=src/models/*.subscriber.ts
DB_MIGRATIONS=src/migrations/*.ts

POSTGRES_DB=maindb
POSTGRES_USER=maindb
POSTGRES_PASSWORD=maindb

JWT_SECRET_KEY=super-secret-key
JWT_TOKEN_TYPE=Bearer
JWT_ACCESS_TOKEN_LIFETIME=3600

SERVICE_TOKEN=dev-service-token

AUTH_USER_SERVICE_URL=http://auth-user-service:3001/api/v1
COMPANY_SERVICE_URL=http://company-service:3002/api/v1
DICTIONARY_SERVICE_URL=http://dictionary-service:3003/api/v1
VACANCY_SERVICE_URL=http://vacancy-service:3004/api/v1
RESUME_SERVICE_URL=http://resume-service:3005/api/v1
APPLICATION_SERVICE_URL=http://application-service:3006/api/v1
INTERACTION_SERVICE_URL=http://interaction-service:3007/api/v1

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=job-platform.events
APPLICATION_CREATED_QUEUE=interaction.application.created
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
