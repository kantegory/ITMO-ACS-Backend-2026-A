      "name": "Регистрация автора",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Статус код 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const response = pm.response.json();",
              "",
              "pm.test(\"Ответ содержит все требуемые поля\", function () {",
              "    pm.expect(response).to.have.property(\"id\");",
              "    pm.expect(response).to.have.property(\"username\");",
              "    pm.expect(response).to.have.property(\"firstName\");",
              "    pm.expect(response).to.have.property(\"lastName\");",
              "    pm.expect(response).to.have.property(\"role\");",
              "});",
              "",
              "pm.test(\"Username совпадает с ожидаемым\", function () {",
              "    const expectedUsername = pm.collectionVariables.get(\"authorUsername\");",
              "    pm.expect(response.username).to.eql(expectedUsername);",
              "});",
              "",
              "pm.collectionVariables.set(\"authorId\", response.id);",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
