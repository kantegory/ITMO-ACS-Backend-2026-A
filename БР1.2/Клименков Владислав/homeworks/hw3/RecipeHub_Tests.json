      "name": "Поиск рецептов с фильтром difficulty=easy (должен вернуть только 2-й рецепт)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Статус код 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const response = pm.response.json();",
              "",
              "pm.test(\"Ответ является массивом\", function () {",
              "    pm.expect(Array.isArray(response)).to.be.true;",
              "});",
              "",
              "const recipeIds = response.map(recipe => recipe.id);",
              "",
              "const recipe1Id = pm.collectionVariables.get(\"recipe1Id\");",
              "const recipe2Id = pm.collectionVariables.get(\"recipe2Id\");",
              "",
              "pm.test(\"В списке присутствует 2-й рецепт\", function () {",
              "    pm.expect(recipeIds).to.include(recipe2Id);",
              "});",
              "",
              "pm.test(\"В списке отсутствует 1-й рецепт\", function () {",
              "    pm.expect(recipeIds).to.not.include(recipe1Id);",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
