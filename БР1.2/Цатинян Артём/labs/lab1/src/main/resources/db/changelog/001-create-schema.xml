<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-users" author="codex">
        <createTable schemaName="storage" tableName="users">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password_hash" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="phone" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(30)" defaultValue="CUSTOMER">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-create-restaurants" author="codex">
        <createTable schemaName="storage" tableName="restaurants">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="phone" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="varchar(255)"/>
            <column name="country" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="city" type="varchar(120)">
                <constraints nullable="false"/>
            </column>
            <column name="street" type="varchar(120)">
                <constraints nullable="false"/>
            </column>
            <column name="building" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="postal_code" type="varchar(20)"/>
            <column name="price_segment" type="varchar(16)">
                <constraints nullable="false"/>
            </column>
            <column name="booking_policy" type="text"/>
            <column name="is_active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex schemaName="storage" tableName="restaurants" indexName="idx_restaurants_city">
            <column name="city"/>
        </createIndex>
        <createIndex schemaName="storage" tableName="restaurants" indexName="idx_restaurants_price_segment">
            <column name="price_segment"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-create-cuisines" author="codex">
        <createTable schemaName="storage" tableName="cuisines">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="004-create-restaurant-cuisines" author="codex">
        <createTable schemaName="storage" tableName="restaurant_cuisines">
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_restaurant_cuisines_restaurant"
                             referencedTableSchemaName="storage"
                             referencedTableName="restaurants"
                             referencedColumnNames="id"/>
            </column>
            <column name="cuisine_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_restaurant_cuisines_cuisine"
                             referencedTableSchemaName="storage"
                             referencedTableName="cuisines"
                             referencedColumnNames="id"/>
            </column>
        </createTable>
        <addPrimaryKey schemaName="storage"
                       tableName="restaurant_cuisines"
                       columnNames="restaurant_id, cuisine_id"
                       constraintName="pk_restaurant_cuisines"/>
    </changeSet>

    <changeSet id="005-create-working-hours" author="codex">
        <createTable schemaName="storage" tableName="restaurant_working_hours">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_working_hours_restaurant"
                             referencedTableSchemaName="storage"
                             referencedTableName="restaurants"
                             referencedColumnNames="id"/>
            </column>
            <column name="week_day" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="opens_at" type="time"/>
            <column name="closes_at" type="time"/>
            <column name="is_closed" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="006-create-restaurant-tables" author="codex">
        <createTable schemaName="storage" tableName="restaurant_tables">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_restaurant_tables_restaurant"
                             referencedTableSchemaName="storage"
                             referencedTableName="restaurants"
                             referencedColumnNames="id"/>
            </column>
            <column name="table_number" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="seats_count" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="zone_name" type="varchar(100)"/>
            <column name="is_active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex schemaName="storage" tableName="restaurant_tables" indexName="idx_restaurant_tables_restaurant_id">
            <column name="restaurant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="007-create-restaurant-photos" author="codex">
        <createTable schemaName="storage" tableName="restaurant_photos">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_restaurant_photos_restaurant"
                             referencedTableSchemaName="storage"
                             referencedTableName="restaurants"
                             referencedColumnNames="id"/>
            </column>
            <column name="image_url" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="008-create-menu-categories" author="codex">
        <createTable schemaName="storage" tableName="menu_categories">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_menu_categories_restaurant"
                             referencedTableSchemaName="storage"
                             referencedTableName="restaurants"
                             referencedColumnNames="id"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="009-create-menu-items" author="codex">
        <createTable schemaName="storage" tableName="menu_items">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_menu_items_restaurant"
                             referencedTableSchemaName="storage"
                             referencedTableName="restaurants"
                             referencedColumnNames="id"/>
            </column>
            <column name="menu_category_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_menu_items_category"
                             referencedTableSchemaName="storage"
                             referencedTableName="menu_categories"
                             referencedColumnNames="id"/>
            </column>
            <column name="name" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="price_minor" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="currency_code" type="varchar(3)" defaultValue="RUB">
                <constraints nullable="false"/>
            </column>
            <column name="is_available" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex schemaName="storage" tableName="menu_items" indexName="idx_menu_items_restaurant_id">
            <column name="restaurant_id"/>
        </createIndex>
        <createIndex schemaName="storage" tableName="menu_items" indexName="idx_menu_items_menu_category_id">
            <column name="menu_category_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="010-create-bookings" author="codex">
        <createTable schemaName="storage" tableName="bookings">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_bookings_user"
                             referencedTableSchemaName="storage"
                             referencedTableName="users"
                             referencedColumnNames="id"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_bookings_restaurant"
                             referencedTableSchemaName="storage"
                             referencedTableName="restaurants"
                             referencedColumnNames="id"/>
            </column>
            <column name="table_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_bookings_table"
                             referencedTableSchemaName="storage"
                             referencedTableName="restaurant_tables"
                             referencedColumnNames="id"/>
            </column>
            <column name="status" type="varchar(30)" defaultValue="CONFIRMED">
                <constraints nullable="false"/>
            </column>
            <column name="guests_count" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="starts_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="ends_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="special_requests" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex schemaName="storage" tableName="bookings" indexName="idx_bookings_user_id">
            <column name="user_id"/>
        </createIndex>
        <createIndex schemaName="storage" tableName="bookings" indexName="idx_bookings_restaurant_id">
            <column name="restaurant_id"/>
        </createIndex>
        <createIndex schemaName="storage" tableName="bookings" indexName="idx_bookings_table_id">
            <column name="table_id"/>
        </createIndex>
        <createIndex schemaName="storage" tableName="bookings" indexName="idx_bookings_status">
            <column name="status"/>
        </createIndex>
        <createIndex schemaName="storage" tableName="bookings" indexName="idx_bookings_starts_at">
            <column name="starts_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="011-create-reviews" author="codex">
        <createTable schemaName="storage" tableName="reviews">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="booking_id" type="bigint">
                <constraints nullable="false"
                             unique="true"
                             foreignKeyName="fk_reviews_booking"
                             referencedTableSchemaName="storage"
                             referencedTableName="bookings"
                             referencedColumnNames="id"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_reviews_restaurant"
                             referencedTableSchemaName="storage"
                             referencedTableName="restaurants"
                             referencedColumnNames="id"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"
                             foreignKeyName="fk_reviews_user"
                             referencedTableSchemaName="storage"
                             referencedTableName="users"
                             referencedColumnNames="id"/>
            </column>
            <column name="rating" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex schemaName="storage" tableName="reviews" indexName="idx_reviews_restaurant_id">
            <column name="restaurant_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
