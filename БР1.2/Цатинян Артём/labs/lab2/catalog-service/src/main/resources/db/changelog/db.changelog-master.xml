<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-catalog-schema" author="codex">
        <sql>create schema if not exists catalog</sql>

        <createTable schemaName="catalog" tableName="restaurants">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="phone" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="city" type="varchar(120)">
                <constraints nullable="false"/>
            </column>
            <column name="street" type="varchar(120)">
                <constraints nullable="false"/>
            </column>
            <column name="building" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="price_segment" type="varchar(16)">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable schemaName="catalog" tableName="cuisines">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>

        <createTable schemaName="catalog" tableName="restaurant_cuisines">
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="cuisine_id" type="bigint">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable schemaName="catalog" tableName="restaurant_working_hours">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="week_day" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="opens_at" type="time"/>
            <column name="closes_at" type="time"/>
            <column name="is_closed" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable schemaName="catalog" tableName="restaurant_tables">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="table_number" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="seats_count" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="zone_name" type="varchar(100)"/>
            <column name="is_active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable schemaName="catalog" tableName="menu_categories">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable schemaName="catalog" tableName="menu_items">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="menu_category_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(150)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="price_minor" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="currency_code" type="varchar(3)" defaultValue="RUB">
                <constraints nullable="false"/>
            </column>
            <column name="is_available" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable schemaName="catalog" tableName="restaurant_rating_stats">
            <column name="restaurant_id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="average_rating" type="numeric(3,1)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="review_count" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

