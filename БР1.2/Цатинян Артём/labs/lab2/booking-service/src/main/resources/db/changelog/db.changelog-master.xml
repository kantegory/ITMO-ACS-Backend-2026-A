<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-booking-schema" author="codex">
        <sql>create schema if not exists booking</sql>

        <createTable schemaName="booking" tableName="bookings">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="restaurant_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="table_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(30)" defaultValue="CONFIRMED">
                <constraints nullable="false"/>
            </column>
            <column name="guests_count" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="starts_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="ends_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="special_requests" type="text"/>
            <column name="restaurant_name_snapshot" type="varchar(200)">
                <constraints nullable="false"/>
            </column>
            <column name="table_number_snapshot" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="table_seats_snapshot" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex schemaName="booking" tableName="bookings" indexName="idx_bookings_table_time">
            <column name="table_id"/>
            <column name="starts_at"/>
            <column name="ends_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
