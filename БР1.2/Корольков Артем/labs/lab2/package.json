{
  "name": "restaurant-api-node",
  "version": "1.0.0",
  "description": "",
  "main": "dist/app.js",
  "scripts": {
    "start": "tsx src/app.ts",
    "start:monolith": "tsx src/app.ts",
    "start:auth": "tsx services/auth-service/src/app.ts",
    "start:restaurant": "tsx services/restaurant-service/src/app.ts",
    "start:reservation": "tsx services/reservation-service/src/app.ts",
    "start:gateway": "tsx services/api-gateway/src/app.ts",
    "start:micro": "concurrently -n auth,restaurant,reservation,gateway -c blue,green,yellow,magenta \"npm run start:auth\" \"npm run start:restaurant\" \"npm run start:reservation\" \"npm run start:gateway\"",
    "seed": "tsx src/database/seed.ts",
    "seed:auth": "tsx services/auth-service/src/database/seed.ts",
    "seed:restaurant": "tsx services/restaurant-service/src/database/seed.ts",
    "seed:reservation": "tsx services/reservation-service/src/database/seed.ts",
    "seed:micro": "npm run seed:auth && npm run seed:restaurant && npm run seed:reservation",
    "build": "tsc -p tsconfig.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "swagger-ui-express": "^5.0.1",
    "http-proxy-middleware": "^3.0.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.18",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
