    {
      "name": "01 Register User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = String(Date.now()).slice(-8);",
              "pm.collectionVariables.set('uniqueSuffix', suffix);",
              "pm.collectionVariables.set('userEmail', `user_${suffix}@example.com`);",
              "pm.collectionVariables.set('userPhone', `+7900${suffix}`);",
              "pm.collectionVariables.set('userPassword', '123456789');",
              "pm.collectionVariables.set('locationCityRun', `${pm.collectionVariables.get('locationCity')} ${suffix}`);",
              "pm.collectionVariables.set('locationAddressRun', `${pm.collectionVariables.get('locationAddress')} ${suffix}`);",
              "pm.collectionVariables.set('locationDistrictRun', `${pm.collectionVariables.get('locationDistrict')} ${suffix}`);",
              "pm.collectionVariables.set('restaurantTitleRun', `${pm.collectionVariables.get('restaurantTitle')} ${suffix}`);",
              "pm.collectionVariables.set('restaurantEmailRun', `restaurant_${suffix}@example.com`);",
              "pm.collectionVariables.set('tableNumberRun', `${pm.collectionVariables.get('tableNumber')}-${suffix}`);",
              "pm.collectionVariables.set('menuCategoryTitleRun', `${pm.collectionVariables.get('menuCategoryTitle')} ${suffix}`);",
              "pm.collectionVariables.set('menuItemTitleRun', `${pm.collectionVariables.get('menuItemTitle')} ${suffix}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register returns 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Register returns user and tokens', function () {",
              "  pm.expect(json.data.user.id).to.be.a('string');",
              "  pm.expect(json.data.tokens.accessToken).to.be.a('string');",
              "});",
              "pm.collectionVariables.set('userId', json.data.user.id);",
              "pm.collectionVariables.set('userAccessToken', json.data.tokens.accessToken);",
              "pm.collectionVariables.set('userRefreshToken', json.data.tokens.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Max\",\n  \"lastName\": \"Ermakov\",\n  \"email\": \"{{userEmail}}\",\n  \"phone\": \"{{userPhone}}\",\n  \"password\": \"{{userPassword}}\",\n  \"passwordConfirmation\": \"{{userPassword}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/auth/register"
      }
    },
