      "name": "00 Init and Gateway Health",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now().toString();",
              "pm.collectionVariables.set('suffix', suffix);",
              "pm.collectionVariables.set('restaurantEmail', 'restaurant' + suffix + '@example.com');",
              "pm.collectionVariables.set('userEmail', 'postman' + suffix + '@example.com');",
              "pm.collectionVariables.set('userPhone', '+79' + suffix.slice(-9));",
              "['adminToken', 'userToken', 'cuisineId', 'locationId', 'restaurantId', 'tableId', 'menuCategoryId', 'reservationId', 'ratingPollAttempts'].forEach((key) => pm.collectionVariables.unset(key));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('gateway is healthy', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('api-gateway responded', function () {",
              "  pm.expect(json.service).to.eql('api-gateway');",
              "});"
            ]
          }
        }
      ],
