    {
      "name": "16 Wait Rating From RabbitMQ Event",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const attempts = Number(pm.collectionVariables.get('ratingPollAttempts') || 0);",
              "if (attempts > 0) {",
              "  const start = Date.now();",
              "  while (Date.now() - start < 500) {}",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('restaurant detail loaded for rating check', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "const ratingOk = Number(json.data.avgRating) === 5 && Number(json.data.reviewsCount) === 1;",
              "let attempts = Number(pm.collectionVariables.get('ratingPollAttempts') || 0);",
              "if (!ratingOk && attempts < 10) {",
              "  attempts += 1;",
              "  pm.collectionVariables.set('ratingPollAttempts', String(attempts));",
              "  postman.setNextRequest(pm.info.requestName);",
              "} else {",
              "  pm.collectionVariables.unset('ratingPollAttempts');",
              "  pm.test('restaurant rating was updated through RabbitMQ event', function () {",
              "    pm.expect(ratingOk, 'avgRating=' + json.data.avgRating + ', reviewsCount=' + json.data.reviewsCount).to.eql(true);",
              "  });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/restaurants/{{restaurantId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "restaurants",
            "{{restaurantId}}"
          ]
        },
        "description": "Polls catalog-service through api-gateway until the rating event has been consumed from RabbitMQ."
      },
      "response": []
    },
    {
