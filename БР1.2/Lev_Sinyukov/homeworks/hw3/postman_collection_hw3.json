{
  "info": {
    "_postman_id": "f77cbf95-52bc-4d50-a2f9-1f707fba8d0a",
    "name": "Restaurant Booking - E2E Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Комплексный сценарий: health gateway -> introspect token -> поиск ресторанов -> проверка ресторана -> проверка стола -> проверка доступности брони -> сводка отзывов -> проверка пользователя"
  },
  "item": [
    {
      "name": "01. Gateway Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{gatewayUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Health status is ok', function () {",
              "  pm.expect(json.status).to.eql('ok');",
              "});",
              "",
              "pm.collectionVariables.set('lastHealthTimestamp', json.timestamp);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02. Identity Introspect",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{token}}\"\n}"
        },
        "url": "{{identityUrl}}/internal/auth/introspect"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Token is active', function () {",
              "  pm.expect(json.active).to.eql(true);",
              "});",
              "",
              "pm.collectionVariables.set('userId', String(json.user_id));",
              "pm.collectionVariables.set('userEmail', json.email);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03. Search Restaurants via BFF",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{gatewayUrl}}/api/v1/restaurants?name={{restaurantName}}",
          "host": [
            "{{gatewayUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "restaurants"
          ],
          "query": [
            {
              "key": "name",
              "value": "{{restaurantName}}"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Items array exists', function () {",
              "  pm.expect(json.items).to.be.an('array');",
              "});",
              "",
              "pm.test('At least one restaurant found', function () {",
              "  pm.expect(json.items.length).to.be.greaterThan(0);",
              "});",
              "",
              "const first = json.items[0];",
              "pm.collectionVariables.set('restaurantId', String(first.id));",
              "pm.collectionVariables.set('restaurantCity', first.city);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04. Check Restaurant Exists",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{catalogUrl}}/internal/restaurants/{{restaurantId}}/exists"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Restaurant exists and is active', function () {",
              "  pm.expect(json.exists).to.eql(true);",
              "  pm.expect(json.is_active).to.eql(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05. Check Table Exists",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{catalogUrl}}/internal/restaurants/{{restaurantId}}/tables/{{tableId}}/exists"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Table exists', function () {",
              "  pm.expect(json.exists).to.eql(true);",
              "  pm.expect(json.is_active).to.eql(true);",
              "});",
              "",
              "pm.collectionVariables.set('seatsCount', String(json.seats_count));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "06. Check Reservation Availability",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"restaurant_id\": {{restaurantId}},\n  \"table_id\": {{tableId}},\n  \"reservation_start\": \"{{reservationStart}}\",\n  \"reservation_end\": \"{{reservationEnd}}\",\n  \"guests_count\": {{guestsCount}}\n}"
        },
        "url": "{{reservationUrl}}/internal/reservations/availability/check"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Reservation slot is available', function () {",
              "  pm.expect(json.available).to.eql(true);",
              "  pm.expect(json.reason).to.eql('OK');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "07. Review Summary",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{reviewUrl}}/internal/reviews/restaurant/{{restaurantId}}/summary"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Summary has expected fields', function () {",
              "  pm.expect(json.restaurant_id).to.exist;",
              "  pm.expect(json.average_rating).to.be.a('number');",
              "  pm.expect(json.reviews_count).to.be.a('number');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "08. Get User By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{identityUrl}}/internal/users/{{userId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Returned user id equals introspect user id', function () {",
              "  pm.expect(String(json.id)).to.eql(pm.collectionVariables.get('userId'));",
              "});",
              "pm.test('Email looks valid', function () {",
              "  pm.expect(json.email).to.include('@');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "userId", "value": "1" },
    { "key": "restaurantId", "value": "1" },
    { "key": "seatsCount", "value": "4" },
    { "key": "restaurantCity", "value": "" },
    { "key": "lastHealthTimestamp", "value": "" }
  ]
}