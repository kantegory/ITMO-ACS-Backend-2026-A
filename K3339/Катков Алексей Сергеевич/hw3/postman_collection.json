  "item": [
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "01 Register user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('testUsername', `chef_alex_${suffix}`);",
                  "pm.collectionVariables.set('testEmail', `chef_alex_${suffix}@example.com`);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "",
                  "pm.test(\"Response is JSON object\", function () {",
                  "    pm.expect(response).to.be.an(\"object\");",
                  "});",
                  "",
                  "pm.test(\"Response contains message\", function () {",
                  "    pm.expect(response.message).to.exist;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Aleksei\",\n  \"lastName\": \"Katkov\",\n  \"username\": \"chef_alex_2026_test2\",\n  \"email\": \"chef_alex_2026_test2@example.com\",\n  \"password\": \"StrongPassword123\"\n}",
              "options": {
