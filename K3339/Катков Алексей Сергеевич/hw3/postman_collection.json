                  "    pm.expect(response.user).to.exist;",
                  "});",
                  "",
                  "pm.test(\"User id exists\", function () {",
                  "    pm.expect(response.user.id).to.exist;",
                  "});",
                  "",
                  "pm.test(\"User email is correct\", function () {",
                  "    pm.expect(response.user.email).to.include(\"@example.com\");",
                  "});",
                  "",
                  "pm.collectionVariables.set(\"token\", response.accessToken);",
                  "pm.collectionVariables.set(\"userId\", response.user.id);"
